@using BookHiveLibrary.Models
@model IEnumerable<ComputerUnit>
@{
    Layout = "~/Views/Shared/_LibrarianLayout.cshtml";
    ViewData["Title"] = "Computer Management";
}

<!-- Stats Row -->
<div class="grid grid-cols-4 gap-4 mb-6">
    <div class="rounded-xl p-4 text-white" style="background-color:#4a6fa5;">
        <p class="text-xs text-blue-200 mb-1">Total Computer</p>
        <p class="text-3xl font-bold">@ViewBag.TotalComputers</p>
    </div>
    <div class="rounded-xl p-4 text-white" style="background-color:#4a6fa5;">
        <p class="text-xs text-blue-200 mb-1">Available</p>
        <p class="text-3xl font-bold">@ViewBag.AvailableComputers</p>
    </div>
    <div class="rounded-xl p-4 text-white" style="background-color:#4a6fa5;">
        <p class="text-xs text-blue-200 mb-1">In Use</p>
        <p class="text-3xl font-bold">@ViewBag.InUseComputers</p>
    </div>
    <div class="rounded-xl p-4 text-white" style="background-color:#4a6fa5;">
        <p class="text-xs text-blue-200 mb-1">Archive</p>
        <p class="text-3xl font-bold">@ViewBag.ArchivedComputers</p>
    </div>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
    <h2 class="font-bold text-gray-700 mb-5">Archive Computers</h2>

    @if (!Model.Any())
    {
        <p class="text-center text-gray-400 py-10">No archived computers</p>
    }
    else
    {
        <div class="grid grid-cols-3 gap-4">
            @foreach (var pc in Model)
            {
                <div class="border border-gray-200 rounded-xl p-4">
                    <div class="flex items-center justify-between mb-2">
                        <p class="font-semibold text-gray-800">@pc.ComputerNumber</p>
                        <span class="px-2 py-0.5 bg-gray-100 text-gray-600 rounded-full text-xs">Archived</span>
                    </div>
                    @if (!string.IsNullOrEmpty(pc.ArchiveReason))
                    {
                        <p class="text-xs text-gray-500 mb-3">Reason: @pc.ArchiveReason</p>
                    }
                    <p class="text-xs text-gray-400 mb-3">@pc.CreatedAt.ToString("MMM dd, yyyy")</p>
                    <div class="flex gap-2">
                        <form method="post" action="@Url.Action("Restore","Computer")">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@pc.Id" />
                            <button type="submit"
                                    class="px-4 py-1.5 bg-green-500 text-white rounded text-xs hover:bg-green-600">Restore</button>
                        </form>
                        <form method="post" action="@Url.Action("Delete","Computer")"
                              onsubmit="return confirm('Permanently delete @pc.ComputerNumber?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@pc.Id" />
                            <button type="submit"
                                    class="px-4 py-1.5 bg-red-500 text-white rounded text-xs hover:bg-red-600">Delete</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>
