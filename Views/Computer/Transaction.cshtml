@using BookHiveLibrary.Models
@model IEnumerable<ComputerUnit>
@{
    Layout = "~/Views/Shared/_LibrarianLayout.cshtml";
    ViewData["Title"] = "Transaction Management - Computer";
    var advisers     = ViewBag.SectionAdvisers as Dictionary<string,string> ?? new Dictionary<string,string>();
    var activeSessions = Model.Select(pc => new {
        pc,
        sess = pc.Sessions.FirstOrDefault(s => s.IsActive)
    }).Where(x => x.sess != null).ToList();
}

<div class="flex gap-5">

    <!-- LEFT: Computer Usage Grid -->
    <div class="flex-1 min-w-0">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
                <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                <h2 class="font-bold text-gray-700">Computer Usage</h2>
            </div>

            <div class="grid grid-cols-3 gap-3 p-4">
                @foreach (var pc in Model)
                {
                    var sess    = pc.Sessions.FirstOrDefault(s => s.IsActive);
                    var inUse   = sess != null;
                    var sect    = sess?.User?.Section ?? "";
                    var adviser = (!string.IsNullOrEmpty(sect) && advisers.TryGetValue(sect, out var a)) ? a : "";
                    <div class="border rounded-xl p-3 @(inUse ? "border-blue-200 bg-blue-50/40" : "border-gray-200 bg-white")">
                        <!-- Top: PC name + status -->
                        <div class="mb-2">
                            <p class="font-bold text-gray-800 text-sm leading-tight truncate">@pc.ComputerNumber</p>
                            <span class="text-[11px] font-medium @(inUse ? "text-red-500" : "text-green-600")">● @(inUse ? "In Use" : "Available")</span>
                        </div>
                        @if (inUse && sess?.User != null)
                        {
                            <p class="text-[11px] text-gray-500 truncate leading-tight">@sess.User.LastName, @sess.User.FirstName</p>
                            <span class="duration-badge inline-block mt-1 text-[10px] font-semibold px-1.5 py-0.5 rounded" style="background:#1e3a6e; color:white;" data-start="@sess.StartTime.ToString("o")">—</span>
                        }
                        <!-- Button: bottom right -->
                        <div class="flex justify-end mt-2">
                            @if (!inUse && pc.IsAvailable)
                            {
                                <button onclick="openAssignModal(@pc.Id, '@pc.ComputerNumber')"
                                        class="px-3 py-1 text-[11px] font-medium text-white rounded-lg" style="background:#1e3a6e;">
                                    Assign
                                </button>
                            }
                            @if (inUse && sess != null)
                            {
                                <button onclick="showSlip(@pc.Id, '@pc.ComputerNumber', '@(sess.User?.LastName)', '@(sess.User?.FirstName)', '@(sess.User?.MiddleName ?? "")', '@sect', '@adviser', '@sess.StartTime.ToString("o")', @sess.Id)"
                                        class="px-3 py-1 text-[11px] font-medium rounded-lg border border-blue-300 text-blue-700 bg-white hover:bg-blue-50">
                                    View Slip
                                </button>
                            }
                        </div>
                    </div>
                }
                @if (!Model.Any())
                {
                    <div class="col-span-2 py-12 text-center text-gray-400">No computers registered</div>
                }
            </div>
        </div>
    </div>

    <!-- RIGHT: Active Sessions + Student Info -->
    <div class="w-96 flex-shrink-0 flex flex-col gap-4">

        <!-- Active Sessions Panel -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
                <div class="flex items-center gap-2">
                    <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                    </svg>
                    <h3 class="font-bold text-gray-700">Active Session</h3>
                </div>
                <span class="px-2 py-0.5 text-xs font-semibold text-white rounded-full" style="background:#1e3a6e;">@activeSessions.Count</span>
            </div>
            <div class="divide-y divide-gray-100 overflow-y-auto" style="max-height:400px;">
                @if (!activeSessions.Any())
                {
                    <p class="px-5 py-8 text-center text-sm text-gray-400">No active sessions</p>
                }
                @foreach (var x in activeSessions)
                {
                    var totalAllowed = x.sess!.AllowedMinutes + x.sess.ExtendedMinutes;
                    <div class="px-4 py-3">
                        <!-- PC + Name -->
                        <div class="flex items-center gap-2 mb-2">
                            <span class="px-2 py-0.5 text-xs font-bold rounded" style="background:#1e3a6e; color:white;">@x.pc.ComputerNumber</span>
                            <p class="text-sm font-medium text-gray-800 truncate">@x.sess.User?.LastName, @x.sess.User?.FirstName</p>
                        </div>
                        <!-- Duration timer -->
                        <span class="session-timer text-xl font-bold tabular-nums block mb-2" style="color:#111827;"
                              data-start="@x.sess.StartTime.ToString("o")"
                              data-allowed="@(totalAllowed * 60)"
                              data-sessid="@x.sess.Id">00:00:00</span>
                        <!-- Time left row: label + value + extend popup on far right -->
                        <div class="flex items-center gap-1 mb-1.5">
                            <span class="text-xs text-gray-400">Time left</span>
                            <span class="time-left-val flex-1 text-xs font-medium text-gray-800 tabular-nums"
                                  data-sessid="@x.sess.Id"
                                  data-allowed="@(totalAllowed * 60)"
                                  data-start="@x.sess.StartTime.ToString("o")">—</span>
                            <div class="relative">
                                <button onclick="toggleExtendPopup('@x.sess.Id', event)"
                                        class="w-5 h-5 rounded-full border border-gray-300 text-gray-500 hover:border-blue-400 hover:text-blue-600 flex items-center justify-center text-sm font-bold leading-none">+</button>
                                <div id="extpop-@x.sess.Id"
                                     class="hidden absolute right-0 bottom-full mb-2 bg-white border border-gray-200 rounded-xl shadow-lg p-3 z-50 whitespace-nowrap">
                                    <p class="text-xs text-gray-400 mb-2 font-medium">Extend time by</p>
                                    <div class="flex gap-2">
                                        @foreach (var mins in new[] { 15, 30, 60 })
                                        {
                                            <button onclick="extendTime(@x.sess.Id, @mins, this)"
                                                    class="px-2.5 py-1 text-xs font-medium rounded-lg border border-gray-200 text-gray-600 hover:bg-blue-50 hover:border-blue-300 hover:text-blue-700">
                                                +@mins min
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- Progress bar -->
                        <div class="w-full bg-gray-100 rounded-full h-1.5">
                            <div class="progress-bar h-1.5 rounded-full transition-all"
                                 style="width:0%; background:#1e3a6e;"
                                 data-start="@x.sess.StartTime.ToString("o")"
                                 data-allowed="@(totalAllowed * 60)"></div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Computer Access / Student Info Panel -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden flex-1">
            <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
                <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
                <div>
                    <h3 class="font-bold text-gray-700 leading-tight">Computer Access</h3>
                    <p class="text-xs text-gray-400">Student information</p>
                </div>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-xs">
                    <thead style="background:#1e3a6e;">
                        <tr>
                            <th class="px-3 py-2.5 text-left text-white font-medium">PC</th>
                            <th class="px-3 py-2.5 text-left text-white font-medium">Name</th>
                            <th class="px-3 py-2.5 text-left text-white font-medium">Section</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @if (!activeSessions.Any())
                        {
                            <tr><td colspan="3" class="px-3 py-6 text-center text-gray-400">No active sessions</td></tr>
                        }
                        @foreach (var x in activeSessions)
                        {
                            <tr class="hover:bg-gray-50">
                                <td class="px-3 py-2.5 font-semibold text-gray-700">@x.pc.ComputerNumber</td>
                                <td class="px-3 py-2.5 text-gray-700 max-w-[80px] truncate">@x.sess!.User?.LastName, @x.sess.User?.FirstName</td>
                                <td class="px-3 py-2.5 text-gray-500">@(x.sess.User?.Section ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- ── Use Slip Modal ──────────────────────────────────────────────────── -->
<div id="slipModal" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 hidden">
    <div class="bg-white rounded-xl shadow-xl w-[480px] overflow-hidden">
        <div class="px-6 py-4 flex items-center justify-between" style="background-color:#1e3a6e;">
            <div>
                <h3 class="text-base font-semibold text-white">Computer Use Slip</h3>
                <p class="text-xs text-white/60 mt-0.5" id="slipPcLabel">—</p>
            </div>
            <button onclick="closeSlipModal()" class="text-white/60 hover:text-white">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>
        <div class="px-6 py-5">
            <div class="grid grid-cols-2 gap-x-6 gap-y-4 text-sm">
                <div><p class="text-xs text-gray-400 mb-0.5">Last Name</p><p id="slipLastName" class="font-medium text-gray-800 border-b border-gray-200 pb-1">—</p></div>
                <div><p class="text-xs text-gray-400 mb-0.5">First Name</p><p id="slipFirstName" class="font-medium text-gray-800 border-b border-gray-200 pb-1">—</p></div>
                <div><p class="text-xs text-gray-400 mb-0.5">M.I.</p><p id="slipMI" class="font-medium text-gray-800 border-b border-gray-200 pb-1">—</p></div>
                <div><p class="text-xs text-gray-400 mb-0.5">Section</p><p id="slipSection" class="font-medium text-gray-800 border-b border-gray-200 pb-1">—</p></div>
                <div class="col-span-2"><p class="text-xs text-gray-400 mb-0.5">Adviser</p><p id="slipAdviser" class="font-medium text-gray-800 border-b border-gray-200 pb-1">—</p></div>
                <div><p class="text-xs text-gray-400 mb-0.5">Start Time</p><p id="slipStartTime" class="text-gray-700 border-b border-gray-200 pb-1">—</p></div>
                <div><p class="text-xs text-gray-400 mb-0.5">Duration</p><p id="slipDuration" class="font-semibold border-b border-gray-200 pb-1" style="color:#1e3a6e;">—</p></div>
            </div>
        </div>
        <div class="px-6 py-4 border-t border-gray-100 flex gap-3">
            <button onclick="closeSlipModal()" class="flex-1 py-2.5 bg-gray-100 text-gray-700 rounded-lg text-sm hover:bg-gray-200">Close</button>
            <form method="post" action="@Url.Action("EndSession","Computer")" class="flex-1">
                @Html.AntiForgeryToken()
                <input type="hidden" id="slipSessionId" name="sessionId" />
                <button type="submit" class="w-full py-2.5 text-white rounded-lg text-sm font-medium bg-red-500 hover:bg-red-600">End Session</button>
            </form>
        </div>
    </div>
</div>

<!-- ── Assign Modal ───────────────────────────────────────────────────── -->
<div id="assignModal" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 hidden">
    <div class="bg-white rounded-xl shadow-xl w-[480px] overflow-hidden">
        <div class="px-6 py-4 flex items-center justify-between" style="background-color:#1e3a6e;">
            <div>
                <h3 class="text-base font-semibold text-white">Assign Computer</h3>
                <p class="text-xs text-white/60 mt-0.5" id="assignPcLabel">—</p>
            </div>
            <button onclick="closeAssignModal()" class="text-white/60 hover:text-white">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>
        <form method="post" action="@Url.Action("StartSession","Computer")">
            @Html.AntiForgeryToken()
            <input type="hidden" name="computerId" id="assignComputerId" />
            <input type="hidden" name="userId"     id="assignUserId" />
            <div class="px-6 pt-5 pb-4">
                <!-- RFID tap -->
                <div class="mb-4">
                    <p class="text-xs text-gray-400 mb-1">Tap RFID Card</p>
                    <div class="flex items-center gap-2 border border-gray-300 rounded-lg px-3 py-2 bg-gray-50 focus-within:ring-2 focus-within:ring-blue-300 cursor-text"
                         onclick="document.getElementById('assignRfidInput').focus()">
                        <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
                        </svg>
                        <input id="assignRfidInput" type="text" placeholder="Tap card to identify user..."
                               class="text-sm w-full focus:outline-none bg-transparent text-gray-700" autocomplete="off" />
                    </div>
                    <p id="assignRfidError" class="text-xs text-red-500 mt-1 hidden"></p>
                </div>

                <!-- Slip divider -->
                <div class="border-t border-dashed border-gray-200 mb-4"></div>

                <!-- Name row -->
                <div class="grid grid-cols-3 gap-x-4 gap-y-3 mb-3">
                    <div class="col-span-1">
                        <p class="text-xs text-gray-400 mb-0.5">Last Name</p>
                        <p id="assignLastName" class="text-sm font-medium text-gray-800 border-b border-gray-200 pb-1 min-h-[1.4rem]">—</p>
                    </div>
                    <div class="col-span-1">
                        <p class="text-xs text-gray-400 mb-0.5">First Name</p>
                        <p id="assignFirstName" class="text-sm font-medium text-gray-800 border-b border-gray-200 pb-1 min-h-[1.4rem]">—</p>
                    </div>
                    <div>
                        <p class="text-xs text-gray-400 mb-0.5">M.I.</p>
                        <p id="assignMI" class="text-sm font-medium text-gray-800 border-b border-gray-200 pb-1 min-h-[1.4rem]">—</p>
                    </div>
                </div>

                <!-- Section + Adviser -->
                <div class="grid grid-cols-2 gap-x-4 gap-y-3 mb-3">
                    <div>
                        <p class="text-xs text-gray-400 mb-0.5">Section</p>
                        <p id="assignSection" class="text-sm font-medium text-gray-800 border-b border-gray-200 pb-1 min-h-[1.4rem]">—</p>
                    </div>
                    <div>
                        <p class="text-xs text-gray-400 mb-0.5">Adviser</p>
                        <p id="assignAdviser" class="text-sm font-medium text-gray-800 border-b border-gray-200 pb-1 min-h-[1.4rem]">—</p>
                    </div>
                </div>

                <!-- Date + Time + Time Limit -->
                <div class="grid grid-cols-3 gap-x-4 gap-y-3">
                    <div>
                        <p class="text-xs text-gray-400 mb-0.5">Date</p>
                        <p id="assignDate" class="text-sm font-medium text-gray-800 border-b border-gray-200 pb-1 min-h-[1.4rem]">—</p>
                    </div>
                    <div>
                        <p class="text-xs text-gray-400 mb-0.5">Time</p>
                        <p id="assignTime" class="text-sm font-medium text-gray-800 border-b border-gray-200 pb-1 min-h-[1.4rem]">—</p>
                    </div>
                    <div>
                        <p class="text-xs text-gray-400 mb-0.5">Time Limit</p>
                        <p class="text-sm font-medium border-b border-gray-200 pb-1 min-h-[1.4rem]" style="color:#1e3a6e;">1 hour</p>
                    </div>
                </div>
            </div>
            <div class="px-6 py-4 border-t border-gray-100 flex gap-3">
                <button type="button" onclick="closeAssignModal()" class="flex-1 py-2.5 bg-gray-100 text-gray-700 rounded-lg text-sm hover:bg-gray-200">Cancel</button>
                <button type="submit" id="assignSubmitBtn" disabled
                        class="flex-1 py-2.5 text-white rounded-lg text-sm font-medium opacity-50 cursor-not-allowed" style="background-color:#1e3a6e;">
                    Start Session
                </button>
            </div>
        </form>
    </div>
</div>


@section Scripts {
<script>
function fmt(startISO) {
    const s = Math.floor((Date.now() - new Date(startISO)) / 1000);
    const h = Math.floor(s / 3600), m = Math.floor((s % 3600) / 60), sec = s % 60;
    return String(h).padStart(2,'0') + ':' + String(m).padStart(2,'0') + ':' + String(sec).padStart(2,'0');
}

function tickAll() {
    // Duration badges on PC cards
    document.querySelectorAll('.duration-badge').forEach(el => el.textContent = fmt(el.dataset.start));

    // Slip modal duration
    if (slipStartISO) document.getElementById('slipDuration').textContent = fmt(slipStartISO);

    // Active session timers + progress bars
    document.querySelectorAll('.session-timer').forEach(el => {
        const elapsed   = Math.floor((Date.now() - new Date(el.dataset.start)) / 1000);
        const allowed   = parseInt(el.dataset.allowed);
        const pct       = Math.min(elapsed / allowed * 100, 100);
        const remaining = allowed - elapsed;

        el.textContent = fmt(el.dataset.start);

        // Timer always black
        el.style.color = '#111827';

        if (remaining <= 0 && !el.dataset.autoending) {
            el.dataset.autoending = '1';
            autoEndSession(parseInt(el.dataset.sessid), el.closest('.px-4.py-3'));
        }

        // Progress bar for same session
        const bar = document.querySelector(`.progress-bar[data-start="${el.dataset.start}"]`);
        if (bar) {
            bar.style.width = pct + '%';
            bar.style.background = remaining <= 0 ? '#dc2626' : remaining <= 600 ? '#d97706' : '#1e3a6e';
        }

        // Time left label (always black text)
        const tlv = document.querySelector(`.time-left-val[data-start="${el.dataset.start}"]`);
        if (tlv) {
            if (remaining <= 0) {
                tlv.textContent = 'Expired';
            } else {
                const h = Math.floor(remaining / 3600);
                const m = Math.floor((remaining % 3600) / 60);
                const s = remaining % 60;
                if (h > 0) tlv.textContent = h + 'h ' + m + 'm left';
                else if (m > 0) tlv.textContent = m + ' min ' + (s ? s + 's ' : '') + 'left';
                else tlv.textContent = s + ' sec left';
            }
        }
    });
}

setInterval(tickAll, 1000);
tickAll();

// Auto-end expired session
async function autoEndSession(sessionId, rowEl) {
    try {
        const fd = new FormData();
        fd.append('sessionId', sessionId);
        fd.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);
        const res  = await fetch('@Url.Action("EndSessionAjax","Computer")', { method: 'POST', body: fd });
        const data = await res.json();
        if (data.success) {
            // Fade out and remove the session row
            if (rowEl) {
                rowEl.style.transition = 'opacity .5s';
                rowEl.style.opacity = '0';
                setTimeout(() => rowEl.remove(), 500);
            }
            // Update the matching PC card to Available
            document.querySelectorAll('.duration-badge').forEach(b => {
                const card = b.closest('[class*="border rounded-xl"]');
                if (!card) return;
                // find matching card by session start — just reload to be safe
            });
            // Reload page after short delay so PC card flips to Available
            setTimeout(() => location.reload(), 1200);
        }
    } catch { /* silent */ }
}

// Extend popup toggle
function toggleExtendPopup(sessId, e) {
    e.stopPropagation();
    const pop = document.getElementById('extpop-' + sessId);
    document.querySelectorAll('[id^="extpop-"]').forEach(p => { if (p !== pop) p.classList.add('hidden'); });
    pop.classList.toggle('hidden');
}
document.addEventListener('click', () => document.querySelectorAll('[id^="extpop-"]').forEach(p => p.classList.add('hidden')));

// Extend time
async function extendTime(sessionId, minutes, btn) {
    btn.disabled = true;
    btn.textContent = '...';
    try {
        const fd = new FormData();
        fd.append('sessionId', sessionId);
        fd.append('minutes', minutes);
        fd.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

        const res  = await fetch('@Url.Action("ExtendTime","Computer")', { method:'POST', body: fd });
        const data = await res.json();

        if (data.success) {
            // Update allowed seconds on timer element
            const timer = document.querySelector(`.session-timer[data-sessid="${sessionId}"]`);
            if (timer) timer.dataset.allowed = data.totalMinutes * 60;

            // Update progress bar allowed
            const bars = document.querySelectorAll(`.progress-bar`);
            bars.forEach(b => {
                const t = document.querySelector(`.session-timer[data-start="${b.dataset.start}"]`);
                if (t && t.dataset.sessid == sessionId) b.dataset.allowed = data.totalMinutes * 60;
            });

            // Close popup
            const pop = document.getElementById('extpop-' + sessionId);
            if (pop) pop.classList.add('hidden');

            // Sync time-left-val data-allowed
            const tlv = document.querySelector(`.time-left-val[data-sessid="${sessionId}"]`);
            if (tlv) tlv.dataset.allowed = data.totalMinutes * 60;

            btn.textContent = '+' + minutes + ' min';
            btn.style.background = '#dcfce7';
            btn.style.borderColor = '#86efac';
            btn.style.color = '#166534';
            setTimeout(() => {
                btn.style.background = '';
                btn.style.borderColor = '';
                btn.style.color = '';
                btn.disabled = false;
            }, 2000);
        }
    } catch {
        btn.textContent = '+' + minutes + ' min';
        btn.disabled = false;
    }
}

// ── Slip ──────────────────────────────────────────────────────────────────────
let slipStartISO = null;
function showSlip(pcId, pcNo, ln, fn, mn, sect, adviser, startISO, sessionId) {
    document.getElementById('slipPcLabel').textContent   = 'PC No. ' + pcNo;
    document.getElementById('slipLastName').textContent  = ln      || '—';
    document.getElementById('slipFirstName').textContent = fn      || '—';
    document.getElementById('slipMI').textContent        = mn      ? mn[0] + '.' : '—';
    document.getElementById('slipSection').textContent   = sect    || '—';
    document.getElementById('slipAdviser').textContent   = adviser || '—';
    document.getElementById('slipSessionId').value       = sessionId;
    slipStartISO = startISO;
    document.getElementById('slipStartTime').textContent = new Date(startISO).toLocaleString('en-US',{month:'2-digit',day:'2-digit',hour:'2-digit',minute:'2-digit',hour12:true});
    document.getElementById('slipModal').classList.remove('hidden');
}
function closeSlipModal() { slipStartISO = null; document.getElementById('slipModal').classList.add('hidden'); }

// ── Assign ────────────────────────────────────────────────────────────────────
let rfidBuf = '', rfidTimer = null;
function openAssignModal(pcId, pcNo) {
    document.getElementById('assignComputerId').value = pcId;
    document.getElementById('assignPcLabel').textContent = 'PC No. ' + pcNo;
    document.getElementById('assignUserId').value = '';
    document.getElementById('assignRfidInput').value = '';
    document.getElementById('assignRfidError').classList.add('hidden');
    const btn = document.getElementById('assignSubmitBtn');
    btn.disabled = true; btn.classList.add('opacity-50','cursor-not-allowed');
    ['assignLastName','assignFirstName','assignMI','assignSection','assignAdviser'].forEach(id => document.getElementById(id).textContent = '—');
    const now = new Date();
    document.getElementById('assignDate').textContent = now.toLocaleDateString('en-US', { month: '2-digit', day: '2-digit', year: 'numeric' });
    document.getElementById('assignTime').textContent = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: true });
    document.getElementById('assignModal').classList.remove('hidden');
    setTimeout(() => document.getElementById('assignRfidInput').focus(), 50);
}
function closeAssignModal() { document.getElementById('assignModal').classList.add('hidden'); }

const rfidEl = document.getElementById('assignRfidInput');
rfidEl.addEventListener('keydown', e => {
    if (e.key === 'Enter') { e.preventDefault(); const v = rfidBuf.trim(); rfidBuf = ''; if (v) lookup(v); }
});
rfidEl.addEventListener('input', function() {
    rfidBuf = this.value; clearTimeout(rfidTimer);
    rfidTimer = setTimeout(() => { const v = rfidBuf.trim(); rfidBuf = ''; rfidEl.value = ''; if (v.length >= 4) lookup(v); }, 200);
});
async function lookup(rfid) {
    const errEl = document.getElementById('assignRfidError');
    errEl.classList.add('hidden'); rfidEl.placeholder = 'Looking up...';
    try {
        const data = await fetch(`@Url.Action("FindUserByRfid","Computer")?rfid=${encodeURIComponent(rfid)}`).then(r => r.json());
        if (!data.found) { errEl.textContent = data.message; errEl.classList.remove('hidden'); }
        else {
            document.getElementById('assignLastName').textContent  = data.lastName    || '—';
            document.getElementById('assignFirstName').textContent = data.firstName   || '—';
            document.getElementById('assignMI').textContent        = data.middleName  ? data.middleName[0] + '.' : '—';
            document.getElementById('assignSection').textContent   = data.section     || '—';
            document.getElementById('assignAdviser').textContent   = data.adviserName || '—';
            document.getElementById('assignUserId').value          = data.userId;
            const btn = document.getElementById('assignSubmitBtn');
            btn.disabled = false; btn.classList.remove('opacity-50','cursor-not-allowed');
        }
    } catch { errEl.textContent = 'Server error.'; errEl.classList.remove('hidden'); }
    rfidEl.placeholder = 'Tap card to identify user...';
}

</script>
}
