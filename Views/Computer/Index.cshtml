@using BookHiveLibrary.Models
@model IEnumerable<ComputerUnit>
@{
    Layout = "~/Views/Shared/_LibrarianLayout.cshtml";
    ViewData["Title"] = "Computer List";
}

<!-- Stats Row -->
<div class="grid grid-cols-4 gap-4 mb-6">
    <div class="rounded-xl p-4 text-white" style="background-color:#4a6fa5;">
        <p class="text-xs text-blue-200 mb-1">Total Computers</p>
        <p class="text-3xl font-bold">@ViewBag.TotalComputers</p>
    </div>
    <div class="rounded-xl p-4 text-white" style="background-color:#4a6fa5;">
        <p class="text-xs text-blue-200 mb-1">Available</p>
        <p class="text-3xl font-bold">@ViewBag.AvailableComputers</p>
    </div>
    <div class="rounded-xl p-4 text-white" style="background-color:#4a6fa5;">
        <p class="text-xs text-blue-200 mb-1">In Use</p>
        <p class="text-3xl font-bold">@ViewBag.InUseComputers</p>
    </div>
    <div class="rounded-xl p-4 text-white" style="background-color:#4a6fa5;">
        <p class="text-xs text-blue-200 mb-1">Archived</p>
        <p class="text-3xl font-bold">@ViewBag.ArchivedComputers</p>
    </div>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100">
    <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
        <h2 class="font-bold text-gray-700 text-sm uppercase tracking-wide">Registered Computers</h2>
        <a href="@Url.Action("Register","Computer")"
           class="px-4 py-2 text-sm text-white rounded-lg" style="background-color:#1e3a6e;">+ Add Computer</a>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="text-gray-500 text-xs uppercase bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left font-semibold">PC No.</th>
                    <th class="px-6 py-3 text-left font-semibold">Status</th>
                    <th class="px-6 py-3 text-right font-semibold"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @foreach (var pc in Model)
                {
                    var inUse = pc.Sessions.Any(s => s.IsActive);
                    <tr class="hover:bg-gray-50">
                        <td class="px-6 py-4 font-semibold text-gray-800">@pc.ComputerNumber</td>
                        <td class="px-6 py-4">
                            @if (inUse)
                            {
                                <span class="px-2 py-1 bg-blue-100 text-blue-700 rounded-full text-xs font-medium">In Use</span>
                            }
                            else if (pc.IsAvailable)
                            {
                                <span class="px-2 py-1 bg-green-100 text-green-700 rounded-full text-xs font-medium">Available</span>
                            }
                            else
                            {
                                <span class="px-2 py-1 bg-gray-100 text-gray-500 rounded-full text-xs font-medium">Unavailable</span>
                            }
                        </td>
                        <td class="px-6 py-4 text-right">
                            <button onclick="showArchiveModal(@pc.Id, '@pc.ComputerNumber')"
                                    class="text-gray-400 hover:text-red-500 p-1">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8l1 12a2 2 0 002 2h8a2 2 0 002-2l1-12"/>
                                </svg>
                            </button>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="3" class="px-6 py-10 text-center text-gray-400">No computers registered yet</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Archive Modal -->
<div id="archiveModal" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 hidden">
    <div class="bg-white rounded-xl p-6 w-96 shadow-xl">
        <h3 class="text-base font-semibold text-gray-800 mb-1">Archive Computer</h3>
        <p class="text-sm text-gray-500 mb-4">PC No. : <span id="archivePcLabel" class="font-medium text-gray-800"></span></p>
        <form method="post" action="@Url.Action("Archive","Computer")">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="archivePcId" />
            <div class="mb-4">
                <label class="block text-xs text-gray-500 mb-1">Reason</label>
                <select name="reason" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300">
                    <option value="">Select reason...</option>
                    <option value="Damaged">Damaged</option>
                    <option value="For Repair">For Repair</option>
                    <option value="Decommissioned">Decommissioned</option>
                    <option value="Other">Other</option>
                </select>
            </div>
            <div class="flex gap-3">
                <button type="button" onclick="document.getElementById('archiveModal').classList.add('hidden')"
                        class="flex-1 py-2 bg-gray-100 text-gray-700 rounded-lg text-sm">Cancel</button>
                <button type="submit" class="flex-1 py-2 bg-red-500 text-white rounded-lg text-sm hover:bg-red-600">Archive</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function showArchiveModal(id, name) {
    document.getElementById('archivePcId').value = id;
    document.getElementById('archivePcLabel').textContent = name;
    document.getElementById('archiveModal').classList.remove('hidden');
}
</script>
}
