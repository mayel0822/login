@using BookHiveLibrary.Models
@model IEnumerable<ComputerUnit>
@{
    Layout = "~/Views/Shared/_LibrarianLayout.cshtml";
    ViewData["Title"] = "Computer Management";
}

<!-- Stats Row -->
<div class="grid grid-cols-4 gap-4 mb-6">
    <div class="rounded-xl p-4 text-white" style="background-color:#4a6fa5;">
        <p class="text-xs text-blue-200 mb-1">Total Computer</p>
        <p class="text-3xl font-bold">@ViewBag.TotalComputers</p>
    </div>
    <div class="rounded-xl p-4 text-white" style="background-color:#4a6fa5;">
        <p class="text-xs text-blue-200 mb-1">Available</p>
        <p class="text-3xl font-bold">@ViewBag.AvailableComputers</p>
    </div>
    <div class="rounded-xl p-4 text-white" style="background-color:#4a6fa5;">
        <p class="text-xs text-blue-200 mb-1">In Use</p>
        <p class="text-3xl font-bold">@ViewBag.InUseComputers</p>
    </div>
    <div class="rounded-xl p-4 text-white" style="background-color:#4a6fa5;">
        <p class="text-xs text-blue-200 mb-1">Archive</p>
        <p class="text-3xl font-bold">@ViewBag.ArchivedComputers</p>
    </div>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100">
    <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
        <h2 class="font-bold text-gray-700 text-sm uppercase tracking-wide">List of Computers</h2>
        <a href="@Url.Action("Register","Computer")"
           class="px-4 py-2 text-sm text-white rounded-lg" style="background-color:#1e3a6e;">+ Add Computer</a>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="text-gray-500 text-xs uppercase">
                <tr>
                    <th class="px-6 py-3 text-left font-semibold">PC #</th>
                    <th class="px-6 py-3 text-left font-semibold">Status</th>
                    <th class="px-6 py-3 text-left font-semibold">Current User</th>
                    <th class="px-6 py-3 text-right font-semibold"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @foreach (var pc in Model)
                {
                    var activeSession = pc.Sessions.FirstOrDefault(s => s.IsActive);
                    <tr class="hover:bg-gray-50">
                        <td class="px-6 py-4 font-medium text-gray-800">@pc.ComputerNumber</td>
                        <td class="px-6 py-4">
                            @if (activeSession != null)
                            {
                                <span class="px-2 py-1 bg-blue-100 text-blue-700 rounded-full text-xs font-medium">In Use</span>
                            }
                            else if (pc.IsAvailable)
                            {
                                <span class="px-2 py-1 bg-green-100 text-green-700 rounded-full text-xs font-medium">Available</span>
                            }
                            else
                            {
                                <span class="px-2 py-1 bg-gray-100 text-gray-600 rounded-full text-xs font-medium">Unavailable</span>
                            }
                        </td>
                        <td class="px-6 py-4 text-gray-600">
                            @(activeSession?.User != null ? $"{activeSession.User.FirstName} {activeSession.User.LastName}" : "—")
                        </td>
                        <td class="px-6 py-4 text-right">
                            <button onclick="showEditModal(@pc.Id, '@pc.ComputerNumber', @pc.IsAvailable.ToString().ToLower())"
                                    class="text-gray-400 hover:text-gray-700">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                            </button>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="4" class="px-6 py-10 text-center text-gray-400">No computers registered yet</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Edit/Archive Modal -->
<div id="editModal" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 hidden">
    <div class="bg-white rounded-xl p-6 w-96 shadow-xl">
        <h3 class="text-lg font-semibold text-gray-800 mb-4">Manage Computer</h3>
        <p id="editPcName" class="text-sm text-gray-500 mb-4"></p>

        <div class="flex flex-col gap-3">
            <!-- Toggle status -->
            <form method="post" id="statusForm" action="@Url.Action("StartSession","Computer")">
                @Html.AntiForgeryToken()
                <input type="hidden" name="computerId" id="editPcId" />
                @* Status toggle is done via archive/restore, so just show archive option *@
            </form>

            <!-- Archive -->
            <form method="post" action="@Url.Action("Archive","Computer")" id="archiveForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="archivePcId" />
                <div class="mb-3">
                    <label class="block text-sm font-medium text-gray-600 mb-1">Archive Reason</label>
                    <select name="reason" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300">
                        <option value="">Select reason...</option>
                        <option value="Damaged">Damaged</option>
                        <option value="For Repair">For Repair</option>
                        <option value="Decommissioned">Decommissioned</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <button type="submit" class="w-full py-2 bg-red-50 text-red-600 border border-red-200 rounded-lg text-sm hover:bg-red-100">Archive Computer</button>
            </form>

            <button onclick="closeEditModal()" class="w-full py-2 bg-gray-100 text-gray-700 rounded-lg text-sm hover:bg-gray-200">Close</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
function showEditModal(id, name, isAvailable) {
    document.getElementById('editPcId').value = id;
    document.getElementById('archivePcId').value = id;
    document.getElementById('editPcName').textContent = 'PC: ' + name;
    document.getElementById('editModal').classList.remove('hidden');
}
function closeEditModal() {
    document.getElementById('editModal').classList.add('hidden');
}
</script>
}
