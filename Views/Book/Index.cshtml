@using BookHiveLibrary.Models
@model IEnumerable<Book>
@{
    Layout = "~/Views/Shared/_LibrarianLayout.cshtml";
    ViewData["Title"] = "Book Catalog";
}

<!-- Stats Row -->
<div class="grid grid-cols-4 gap-4 mb-6">
    <div class="rounded-xl p-4 text-white" style="background-color:#4a6fa5;">
        <p class="text-xs text-blue-200 mb-1">Total Books</p>
        <p class="text-3xl font-bold">@Model.Sum(b => b.TotalQuantity)</p>
    </div>
    <div class="rounded-xl p-4 text-white" style="background-color:#4a6fa5;">
        <p class="text-xs text-blue-200 mb-1">Available</p>
        <p class="text-3xl font-bold">@Model.Sum(b => b.AvailableQuantity)</p>
    </div>
    <div class="rounded-xl p-4 text-white" style="background-color:#4a6fa5;">
        <p class="text-xs text-blue-200 mb-1">Borrowed</p>
        <p class="text-3xl font-bold">@Model.Sum(b => b.TotalQuantity - b.AvailableQuantity)</p>
    </div>
    <div class="rounded-xl p-4 text-white" style="background-color:#4a6fa5;">
        <p class="text-xs text-blue-200 mb-1">Titles</p>
        <p class="text-3xl font-bold">@Model.Count()</p>
    </div>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100">
    <!-- Search & Filters -->
    <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-3">
        <form method="get" class="flex flex-1">
            <div class="flex flex-1 border border-gray-300 rounded-lg overflow-hidden focus-within:ring-2 focus-within:ring-blue-300">
                <input type="text" name="search" value="@ViewBag.Search"
                       placeholder="Search by title, author, call number..."
                       class="flex-1 px-3 py-2 text-sm outline-none bg-white" />
                <div class="w-px bg-gray-200 self-stretch"></div>
                <select name="category" class="px-3 py-2 text-sm outline-none bg-white text-gray-600 cursor-pointer">
                    <option value="">All Categories</option>
                    @if (ViewBag.Categories != null)
                    {
                        foreach (var cat in (List<string>)ViewBag.Categories)
                        {
                            <option value="@cat" selected="@(ViewBag.Category == cat ? "selected" : null)">@cat</option>
                        }
                    }
                </select>
                <button type="submit" class="px-4 py-2 text-sm text-white font-medium" style="background-color:#1e3a6e;">Search</button>
            </div>
            @if (!string.IsNullOrEmpty(ViewBag.Search as string) || !string.IsNullOrEmpty(ViewBag.Category as string))
            {
                <a href="@Url.Action("Index","Book")" class="ml-2 px-4 py-2 text-sm bg-gray-100 text-gray-600 rounded-lg hover:bg-gray-200 self-center">Clear</a>
            }
        </form>
        <a href="@Url.Action("Register","Book")"
           class="px-4 py-2 text-sm text-white rounded-lg flex-shrink-0 font-medium" style="background-color:#1e3a6e;">+ Add Book</a>
    </div>

    <!-- Table -->
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 text-gray-500 text-xs uppercase">
                <tr>
                    <th class="px-4 py-3 text-left">Book ID</th>
                    <th class="px-4 py-3 text-left">Book Title</th>
                    <th class="px-4 py-3 text-left">Author</th>
                    <th class="px-4 py-3 text-left">Published Year</th>
                    <th class="px-4 py-3 text-left">Category</th>
                    <th class="px-4 py-3 text-left">Status</th>
                    <th class="px-4 py-3 text-left">Action</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @foreach (var book in Model)
                {
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3 text-gray-600 font-mono text-xs">@book.CallNumber</td>
                        <td class="px-4 py-3 font-medium text-gray-800">@book.Title</td>
                        <td class="px-4 py-3 text-gray-600">@book.Author</td>
                        <td class="px-4 py-3 text-gray-600">@book.PublishedYear</td>
                        <td class="px-4 py-3 text-gray-600">@book.Category</td>
                        <td class="px-4 py-3">
                            @if (book.AvailableQuantity > 0)
                            {
                                <span class="px-2 py-1 bg-green-100 text-green-700 rounded-full text-xs font-medium">Available (@book.AvailableQuantity)</span>
                            }
                            else
                            {
                                <span class="px-2 py-1 bg-red-100 text-red-700 rounded-full text-xs font-medium">Not Available</span>
                            }
                        </td>
                        <td class="px-4 py-3">
                            <div class="flex gap-2 items-center">
                                <a href="@Url.Action("Edit","Book", new { id = book.Id })"
                                   class="text-blue-600 hover:text-blue-800">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                                </a>
                                <a href="@Url.Action("QRCode","Book", new { id = book.Id })" target="_blank"
                                   class="text-gray-400 hover:text-gray-700" title="QR Code">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 3.5a.5.5 0 11-1 0 .5.5 0 011 0zM6 3h4v4H6V3zm0 14h4v4H6v-4zM14 3h4v4h-4V3z"/></svg>
                                </a>
                                <button onclick="showArchiveModal(@book.Id)"
                                        class="text-red-400 hover:text-red-600" title="Archive">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="px-4 py-8 text-center text-gray-400">No books found</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Archive Modal -->
<div id="archiveModal" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 hidden">
    <div class="bg-white rounded-xl p-6 w-96 shadow-xl">
        <h3 class="text-lg font-semibold text-gray-800 mb-4">Archive Book</h3>
        <form method="post" id="archiveForm" action="/Book/Archive">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="archiveBookId" />
            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-600 mb-1">Reason for archiving</label>
                <select name="reason" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300">
                    <option value="">Select reason...</option>
                    <option value="Damaged">Damaged</option>
                    <option value="Lost">Lost</option>
                    <option value="Outdated">Outdated</option>
                    <option value="Replaced">Replaced by new edition</option>
                    <option value="Other">Other</option>
                </select>
            </div>
            <div class="flex gap-3">
                <button type="submit" class="flex-1 py-2 text-white rounded-lg text-sm" style="background-color:#1e3a6e;">Archive</button>
                <button type="button" onclick="closeArchiveModal()" class="flex-1 py-2 bg-gray-100 text-gray-700 rounded-lg text-sm hover:bg-gray-200">Cancel</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function showArchiveModal(id) {
    document.getElementById('archiveBookId').value = id;
    document.getElementById('archiveModal').classList.remove('hidden');
}
function closeArchiveModal() {
    document.getElementById('archiveModal').classList.add('hidden');
}
</script>
}
