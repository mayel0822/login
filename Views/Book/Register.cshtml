@model BookHiveLibrary.ViewModels.BookFormViewModel
@{
    Layout = "~/Views/Shared/_LibrarianLayout.cshtml";
    ViewData["Title"] = "Book Registration";
}

<!-- Stats Row -->
<div class="grid grid-cols-4 gap-4 mb-6">
    <div class="rounded-xl p-4 text-white" style="background-color:#4a6fa5;">
        <p class="text-xs text-blue-200 mb-1">Total Books</p>
        <p class="text-3xl font-bold">@ViewBag.TotalBooks</p>
    </div>
    <div class="rounded-xl p-4 text-white" style="background-color:#4a6fa5;">
        <p class="text-xs text-blue-200 mb-1">Available</p>
        <p class="text-3xl font-bold">@ViewBag.AvailableBooks</p>
    </div>
    <div class="rounded-xl p-4 text-white" style="background-color:#4a6fa5;">
        <p class="text-xs text-blue-200 mb-1">Borrowed</p>
        <p class="text-3xl font-bold">@ViewBag.BorrowedBooks</p>
    </div>
    <div class="rounded-xl p-4 text-white" style="background-color:#4a6fa5;">
        <p class="text-xs text-blue-200 mb-1">Archive</p>
        <p class="text-3xl font-bold">@ViewBag.ArchivedBooks</p>
    </div>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
    <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-gray-800">@(Model.Id == 0 ? "Register New Book" : "Edit Book")</h2>
        <button type="button" onclick="document.getElementById('importModal').classList.remove('hidden')"
                class="px-4 py-2 text-sm text-white rounded-lg font-medium flex items-center gap-2" style="background:#1e3a6e;">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
            Import Excel
        </button>
    </div>

    <!-- Import Excel Modal -->
    <div id="importModal" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 hidden">
        <div class="bg-white rounded-xl shadow-xl w-[600px] overflow-hidden">
            <div class="px-6 py-4 flex items-center justify-between border-b border-gray-100">
                <h3 class="text-base font-semibold text-gray-800">Import from Excel</h3>
                <button type="button" onclick="closeImportModal()" class="text-gray-400 hover:text-gray-600">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
            <div class="px-6 py-5">
                <form id="importForm" method="post" action="@Url.Action("ImportExcel","Book")" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div id="dropZone"
                         ondragover="event.preventDefault(); this.classList.add('border-blue-400','bg-blue-50')"
                         ondragleave="this.classList.remove('border-blue-400','bg-blue-50')"
                         ondrop="handleDrop(event)"
                         onclick="document.getElementById('excelFileInput').click()"
                         class="border-2 border-dashed border-gray-300 rounded-xl p-10 flex flex-col items-center justify-center gap-2 cursor-pointer hover:border-blue-400 hover:bg-blue-50 transition">
                        <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m3.75 9v6m3-3H9m1.5-12H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
                        <p class="text-sm text-gray-500">Drag &amp; drop your Excel file here or</p>
                        <span class="text-sm font-medium text-blue-600 hover:underline">Browse file</span>
                        <p id="selectedFileName" class="text-xs text-gray-400 mt-1">No file selected</p>
                        <input type="file" id="excelFileInput" name="file" accept=".xlsx" class="hidden"
                               onchange="document.getElementById('selectedFileName').textContent = this.files[0]?.name ?? 'No file selected'" />
                    </div>
                </form>
            </div>
            <div class="px-6 py-4 border-t border-gray-100 flex gap-3 justify-end">
                <button type="button" onclick="closeImportModal()" class="px-5 py-2 bg-gray-100 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-200">Cancel</button>
                <button type="button" onclick="submitImport()" class="px-5 py-2 text-white rounded-lg text-sm font-medium" style="background:#1e3a6e;">Import Books</button>
            </div>
        </div>
    </div>

    <form method="post" asp-action="Register">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="mb-4 text-red-600 text-sm"></div>

        <div class="grid grid-cols-2 gap-8">
            <!-- Cover Image Preview -->
            <div class="flex flex-col items-center gap-4">
                <div id="coverPreview" class="w-48 h-64 bg-gray-100 rounded-lg border-2 border-dashed border-gray-300 flex items-center justify-center overflow-hidden">
                    @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
                    {
                        <img id="coverImg" src="@Model.CoverImageUrl" class="w-full h-full object-cover" alt="Cover" />
                    }
                    else
                    {
                        <div id="coverPlaceholder" class="text-center text-gray-400">
                            <svg class="w-12 h-12 mx-auto mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>
                            <p class="text-xs">Cover Preview</p>
                        </div>
                    }
                </div>
                <div class="w-full">
                    <label class="block text-sm font-medium text-gray-600 mb-1">Cover Image URL</label>
                    <input type="text" asp-for="CoverImageUrl" id="coverUrlInput"
                           placeholder="https://..."
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                           oninput="updatePreview(this.value)" />
                </div>
                <div class="w-full">
                    <label class="block text-sm font-medium text-gray-600 mb-1">Total Quantity</label>
                    <input type="number" asp-for="TotalQuantity" min="1"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300" />
                </div>
                <div class="w-full">
                    <label class="block text-sm font-medium text-gray-600 mb-1">Available Quantity</label>
                    <input type="number" asp-for="AvailableQuantity" min="0"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300" />
                </div>
            </div>

            <!-- Book Fields -->
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-600 mb-1">Book Title</label>
                    <input type="text" asp-for="Title" required
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300" />
                    <span asp-validation-for="Title" class="text-red-500 text-xs"></span>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-600 mb-1">Author</label>
                    <input type="text" asp-for="Author" required
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300" />
                </div>
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="block text-sm font-medium text-gray-600 mb-1">Book ID / Call No.</label>
                        <input type="text" asp-for="CallNumber" required
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-600 mb-1">Published Year</label>
                        <input type="text" asp-for="PublishedYear" placeholder="e.g. 2023"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300" />
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="block text-sm font-medium text-gray-600 mb-1">Category</label>
                        <input type="text" asp-for="Category" required
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-600 mb-1">Location / Aisle</label>
                        <input type="text" asp-for="AisleLocation" required
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300" />
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-600 mb-1">Grade Level</label>
                    <input type="text" asp-for="GradeLevel" placeholder="e.g. Grade 10, College"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-600 mb-1">Book Synopsis</label>
                    <textarea asp-for="Description" rows="4"
                              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300 resize-none"></textarea>
                </div>
            </div>
        </div>

        <div class="flex gap-3 mt-6 justify-end">
            <a href="@Url.Action("Index","Book")" class="px-6 py-2 bg-gray-100 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-200">Cancel</a>
            <button type="submit" class="px-6 py-2 text-white rounded-lg text-sm font-medium" style="background-color:#1e3a6e;">
                @(Model.Id == 0 ? "Register Book" : "Save Changes")
            </button>
        </div>
    </form>
</div>

@section Scripts {
<script>
function updatePreview(url) {
    const preview = document.getElementById('coverPreview');
    if (url) {
        preview.innerHTML = '<img src="' + url + '" class="w-full h-full object-cover" onerror="this.style.display=\'none\'" />';
    }
}
function closeImportModal() {
    document.getElementById('importModal').classList.add('hidden');
    document.getElementById('selectedFileName').textContent = 'No file selected';
    document.getElementById('excelFileInput').value = '';
}
function submitImport() {
    const input = document.getElementById('excelFileInput');
    if (!input.files.length) { alert('Please select an Excel file first.'); return; }
    document.getElementById('importForm').submit();
}
function handleDrop(e) {
    e.preventDefault();
    document.getElementById('dropZone').classList.remove('border-blue-400','bg-blue-50');
    const file = e.dataTransfer.files[0];
    if (!file) return;
    const dt = new DataTransfer();
    dt.items.add(file);
    const input = document.getElementById('excelFileInput');
    input.files = dt.files;
    document.getElementById('selectedFileName').textContent = file.name;
}
</script>
}
