@using BookHiveLibrary.Models
@model IEnumerable<ApplicationUser>
@{
    Layout = "~/Views/Shared/_MISLayout.cshtml";
    ViewData["Title"] = "User Information";
    var activeFilter = ViewBag.RoleFilter as string ?? "All";
}

<!-- Search + Filter Row -->
<div class="flex flex-wrap gap-3 items-center justify-between mb-6">
    <!-- Role Filter Buttons -->
    <div class="flex gap-2">
        @foreach (var r in new[] { "All", "Student", "Librarian", "Professor" })
        {
            var isActive = activeFilter == r;
            <a href="@Url.Action("UserInformation","MIS", new { roleFilter = r, search = ViewBag.Search })"
               class="px-5 py-2 rounded-xl text-sm font-medium transition @(isActive ? "text-white" : "border border-gray-300 text-gray-600 hover:bg-gray-50")"
               style="@(isActive ? "background-color:#1B2B5E;" : "")">
                @r
            </a>
        }
    </div>

    <!-- Search -->
    <form method="get" action="@Url.Action("UserInformation","MIS")" class="flex gap-2">
        <input type="hidden" name="roleFilter" value="@activeFilter" />
        <input type="text" name="search" value="@ViewBag.Search"
               placeholder="Search by name, ID, email..."
               class="border border-gray-300 rounded-xl px-4 py-2 text-sm w-64 focus:outline-none focus:ring-2 focus:ring-blue-400" />
        <button type="submit"
                class="px-5 py-2 text-white rounded-xl text-sm" style="background-color:#1B2B5E;">Search</button>
        @if (!string.IsNullOrEmpty(ViewBag.Search as string))
        {
            <a href="@Url.Action("UserInformation","MIS", new { roleFilter = activeFilter })"
               class="px-4 py-2 text-sm text-gray-500 border border-gray-300 rounded-xl hover:bg-gray-50">Clear</a>
        }
    </form>
</div>

<!-- Table -->
<div class="bg-white rounded-2xl shadow overflow-hidden">
    <table class="w-full text-sm">
        <thead class="text-white text-xs uppercase" style="background-color:#1B2B5E;">
            <tr>
                <th class="px-5 py-3 text-left">ID / Emp. No.</th>
                <th class="px-5 py-3 text-left">Last Name</th>
                <th class="px-5 py-3 text-left">First Name</th>
                <th class="px-5 py-3 text-left">Role</th>
                <th class="px-5 py-3 text-left">Email</th>
                <th class="px-5 py-3 text-left">Status</th>
                <th class="px-5 py-3 text-left">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr class="border-b hover:bg-gray-50" data-role="@user.UserType">
                    <td class="px-5 py-3 text-gray-500 font-mono text-xs">
                        @(user.UserType == "Student" ? user.StudentNumber : user.EmployeeNumber)
                    </td>
                    <td class="px-5 py-3 font-medium text-gray-800">@user.LastName</td>
                    <td class="px-5 py-3 text-gray-700">@user.FirstName</td>
                    <td class="px-5 py-3">
                        <span class="px-2 py-1 rounded-full text-xs font-medium
                            @(user.UserType == "Librarian" ? "bg-indigo-100 text-indigo-700" :
                              user.UserType == "Student"   ? "bg-green-100 text-green-700"   :
                              "bg-blue-100 text-blue-700")">
                            @user.UserType
                        </span>
                    </td>
                    <td class="px-5 py-3 text-gray-500">@user.Email</td>
                    <td class="px-5 py-3">
                        @if (user.IsActive)
                        {
                            <span class="bg-green-100 text-green-700 text-xs px-2 py-1 rounded-full">Active</span>
                        }
                        else
                        {
                            <span class="bg-gray-100 text-gray-500 text-xs px-2 py-1 rounded-full">Inactive</span>
                        }
                    </td>
                    <td class="px-5 py-3">
                        <div class="flex items-center gap-2">
                            <a href="/MIS/Edit/@user.Id"
                               class="text-xs px-3 py-1 rounded-lg border border-gray-300 text-gray-600 hover:bg-gray-50">Edit</a>

                            <form method="post" asp-action="ToggleStatus" asp-controller="MIS">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@user.Id" />
                                <input type="hidden" name="returnAction" value="UserInformation" />
                                <button type="submit"
                                        class="text-xs px-3 py-1 rounded-lg border @(user.IsActive ? "border-yellow-300 text-yellow-600 hover:bg-yellow-50" : "border-green-300 text-green-600 hover:bg-green-50")">
                                    @(user.IsActive ? "Deactivate" : "Activate")
                                </button>
                            </form>

                            <form method="post" asp-action="ArchiveUser" asp-controller="MIS"
                                  onsubmit="return confirm('Archive @user.FirstName @user.LastName?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@user.Id" />
                                <button type="submit"
                                        class="text-xs px-3 py-1 rounded-lg border border-red-300 text-red-600 hover:bg-red-50">
                                    Archive
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="7" class="px-5 py-12 text-center text-gray-400">
                        No accounts found.
                        <a href="@Url.Action("Registration","MIS")" class="text-blue-500 hover:underline ml-1">Register one →</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
