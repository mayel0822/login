@using BookHiveLibrary.Models
@model IEnumerable<ApplicationUser>
@{
    Layout = "~/Views/Shared/_MISLayout.cshtml";
    var role = ViewBag.Role as string ?? "User";
    ViewData["Title"] = role + "s";

    var accentClass = role switch {
        "Librarian" => "bg-indigo-700",
        "Student"   => "bg-green-600",
        "Professor" => "bg-blue-600",
        _           => "bg-gray-600"
    };
    var badgeClass = role switch {
        "Librarian" => "bg-indigo-100 text-indigo-700",
        "Student"   => "bg-green-100 text-green-700",
        "Professor" => "bg-blue-100 text-blue-700",
        _           => "bg-gray-100 text-gray-600"
    };
}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-3xl font-bold text-gray-800">@role Accounts</h1>
    <a href="/MIS/Create?role=@role"
       class="@accentClass text-white px-5 py-2.5 rounded-xl text-sm hover:opacity-90">
        + New @role
    </a>
</div>

<!-- Search -->
<form method="get" class="mb-6 flex gap-3">
    <input type="text" name="search" value="@ViewBag.Search"
           placeholder="Search by name, email, ID number..."
           class="border border-gray-300 rounded-xl px-4 py-2 w-80 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
    <button type="submit"
            class="@accentClass text-white px-5 py-2 rounded-xl text-sm hover:opacity-90">
        Search
    </button>
    @if (!string.IsNullOrEmpty(ViewBag.Search as string))
    {
        <a href="/MIS/@(role)s" class="px-5 py-2 text-sm text-gray-500 hover:underline">Clear</a>
    }
</form>

<div class="bg-white rounded-2xl shadow overflow-hidden">
    <table class="w-full text-sm">
        <thead class="@accentClass text-white">
            <tr>
                <th class="px-5 py-3 text-left">Name</th>
                <th class="px-5 py-3 text-left">Email</th>
                <th class="px-5 py-3 text-left">
                    @(role == "Student" ? "Student No." : "Employee No.")
                </th>
                <th class="px-5 py-3 text-left">Section / Dept.</th>
                <th class="px-5 py-3 text-left">Status</th>
                <th class="px-5 py-3 text-left">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr class="border-b hover:bg-gray-50">
                    <td class="px-5 py-3 font-medium">@user.LastName, @user.FirstName @user.MiddleName</td>
                    <td class="px-5 py-3 text-gray-500">@user.Email</td>
                    <td class="px-5 py-3 text-gray-500">
                        @(role == "Student" ? user.StudentNumber : user.EmployeeNumber)
                    </td>
                    <td class="px-5 py-3 text-gray-500">@(string.IsNullOrEmpty(user.Section) ? "—" : user.Section)</td>
                    <td class="px-5 py-3">
                        @if (user.IsActive)
                        {
                            <span class="bg-green-100 text-green-700 text-xs px-2 py-1 rounded-full">Active</span>
                        }
                        else
                        {
                            <span class="bg-gray-100 text-gray-500 text-xs px-2 py-1 rounded-full">Inactive</span>
                        }
                    </td>
                    <td class="px-5 py-3">
                        <div class="flex items-center gap-2">
                            <!-- Edit -->
                            <a href="/MIS/Edit/@user.Id"
                               class="text-xs px-3 py-1 rounded-lg border border-indigo-300 text-indigo-600 hover:bg-indigo-50">
                                Edit
                            </a>

                            <!-- Toggle Active -->
                            <form method="post" asp-action="ToggleStatus" asp-controller="MIS">
                                <input type="hidden" name="id" value="@user.Id" />
                                <input type="hidden" name="returnAction" value="@(role)s" />
                                <button type="submit"
                                        class="text-xs px-3 py-1 rounded-lg border @(user.IsActive ? "border-yellow-300 text-yellow-600 hover:bg-yellow-50" : "border-green-300 text-green-600 hover:bg-green-50")">
                                    @(user.IsActive ? "Deactivate" : "Activate")
                                </button>
                            </form>

                            <!-- Delete -->
                            <form method="post" asp-action="Delete" asp-controller="MIS"
                                  onsubmit="return confirm('Delete @user.FirstName @user.LastName? This cannot be undone.')">
                                <input type="hidden" name="id" value="@user.Id" />
                                <input type="hidden" name="returnAction" value="@(role)s" />
                                <button type="submit"
                                        class="text-xs px-3 py-1 rounded-lg border border-red-300 text-red-600 hover:bg-red-50">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" class="px-5 py-10 text-center text-gray-400">
                        No @role.ToLower() accounts found.
                        <a href="/MIS/Create?role=@role" class="text-indigo-500 hover:underline ml-1">Create one →</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
