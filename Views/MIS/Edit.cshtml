@model BookHiveLibrary.ViewModels.MISEditUserViewModel
@{
    Layout = "~/Views/Shared/_MISLayout.cshtml";
    ViewData["Title"] = "Edit " + Model.Role;
}

<div class="max-w-2xl">

    <div class="flex items-center gap-3 mb-6">
        <a href="/MIS/@(Model.Role)s" class="text-gray-400 hover:text-gray-600 text-sm">← Back</a>
        <h1 class="text-3xl font-bold text-gray-800">Edit @Model.Role Account</h1>
    </div>

    <form method="post" asp-action="Edit" asp-controller="MIS" class="bg-white rounded-2xl shadow p-8 space-y-5">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="Role" />

        <div asp-validation-summary="All" class="bg-red-50 border border-red-200 text-red-700 text-sm px-4 py-3 rounded-xl"></div>

        <!-- Name -->
        <div class="grid grid-cols-3 gap-4">
            <div>
                <label asp-for="FirstName" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="FirstName" class="w-full border border-gray-300 rounded-xl px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
                <span asp-validation-for="FirstName" class="text-red-500 text-xs"></span>
            </div>
            <div>
                <label asp-for="MiddleName" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="MiddleName" class="w-full border border-gray-300 rounded-xl px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
            </div>
            <div>
                <label asp-for="LastName" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="LastName" class="w-full border border-gray-300 rounded-xl px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
                <span asp-validation-for="LastName" class="text-red-500 text-xs"></span>
            </div>
        </div>

        <!-- Email -->
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="Email" type="email" class="w-full border border-gray-300 rounded-xl px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
                <span asp-validation-for="Email" class="text-red-500 text-xs"></span>
            </div>
            <div>
                <label asp-for="OutlookEmail" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="OutlookEmail" type="email" class="w-full border border-gray-300 rounded-xl px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
            </div>
        </div>

        <!-- Role-specific IDs -->
        @if (Model.Role == "Student")
        {
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="StudentNumber" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <input asp-for="StudentNumber" class="w-full border border-gray-300 rounded-xl px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
                </div>
                <div>
                    <label asp-for="Section" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <input asp-for="Section" class="w-full border border-gray-300 rounded-xl px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
                </div>
            </div>
        }
        else
        {
            <div>
                <label asp-for="EmployeeNumber" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="EmployeeNumber" class="w-full border border-gray-300 rounded-xl px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
            </div>
        }

        <!-- Contact & RFID -->
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label asp-for="PhoneNumber" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="PhoneNumber" type="tel" class="w-full border border-gray-300 rounded-xl px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
            </div>
            <div>
                <label asp-for="RFIDNumber" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="RFIDNumber" class="w-full border border-gray-300 rounded-xl px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
            </div>
        </div>

        <!-- Password reset (optional) -->
        <div class="border-t pt-5">
            <p class="text-sm font-medium text-gray-700 mb-3">Change Password <span class="text-gray-400 font-normal">(leave blank to keep current)</span></p>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="NewPassword" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <input asp-for="NewPassword" type="password" class="w-full border border-gray-300 rounded-xl px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
                </div>
                <div>
                    <label asp-for="ConfirmPassword" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <input asp-for="ConfirmPassword" type="password" class="w-full border border-gray-300 rounded-xl px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
                    <span asp-validation-for="ConfirmPassword" class="text-red-500 text-xs"></span>
                </div>
            </div>
        </div>

        <div class="flex gap-3 pt-2">
            <button type="submit"
                    class="bg-indigo-700 text-white px-6 py-2.5 rounded-xl text-sm hover:bg-indigo-800">
                Save Changes
            </button>
            <a href="/MIS/@(Model.Role)s"
               class="px-6 py-2.5 rounded-xl text-sm border border-gray-300 text-gray-600 hover:bg-gray-50">
                Cancel
            </a>
        </div>

    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
