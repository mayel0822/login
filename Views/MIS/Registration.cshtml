@section Scripts {
<script>
function switchTab(tab, btn) {
    // Hide all forms
    document.querySelectorAll('.tab-form').forEach(f => f.classList.add('hidden'));
    // Reset all tab buttons
    document.querySelectorAll('.tab-btn').forEach(b => {
        b.style.backgroundColor = '';
        b.classList.remove('text-white');
        b.classList.add('border', 'border-gray-300', 'text-gray-600');
    });
    // Show selected form
    document.getElementById('form-' + tab).classList.remove('hidden');
    // Activate selected button
    btn.style.backgroundColor = '#1B2B5E';
    btn.classList.add('text-white');
    btn.classList.remove('border', 'border-gray-300', 'text-gray-600');
}
</script>
}
