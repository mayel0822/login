@using BookHiveLibrary.Models
@{
    Layout = "~/Views/Shared/_MISLayout.cshtml";
    ViewData["Title"] = "Dashboard";
    var recentUsers = ViewBag.RecentUsers as List<ApplicationUser> ?? new();
}

<h1 class="text-3xl font-bold mb-6 text-gray-800">MIS Dashboard</h1>

<!-- Stats -->
<div class="grid grid-cols-3 gap-5 mb-8">

    <div class="bg-white rounded-2xl shadow p-6">
        <p class="text-gray-500 text-sm">Librarians</p>
        <p class="text-4xl font-bold text-indigo-700 mt-2">@ViewBag.TotalLibrarians</p>
        <p class="text-xs text-gray-400 mt-1">@ViewBag.ActiveLibrarians active</p>
        <a href="/MIS/Librarians" class="text-xs text-indigo-500 hover:underline mt-2 inline-block">View all →</a>
    </div>

    <div class="bg-white rounded-2xl shadow p-6">
        <p class="text-gray-500 text-sm">Students</p>
        <p class="text-4xl font-bold text-green-600 mt-2">@ViewBag.TotalStudents</p>
        <p class="text-xs text-gray-400 mt-1">@ViewBag.ActiveStudents active</p>
        <a href="/MIS/Students" class="text-xs text-green-500 hover:underline mt-2 inline-block">View all →</a>
    </div>

    <div class="bg-white rounded-2xl shadow p-6">
        <p class="text-gray-500 text-sm">Professors</p>
        <p class="text-4xl font-bold text-blue-600 mt-2">@ViewBag.TotalProfessors</p>
        <p class="text-xs text-gray-400 mt-1">@ViewBag.ActiveProfessors active</p>
        <a href="/MIS/Professors" class="text-xs text-blue-500 hover:underline mt-2 inline-block">View all →</a>
    </div>

</div>

<!-- Quick Create Buttons -->
<div class="flex gap-3 mb-8">
    <a href="/MIS/Registration"
       class="text-white px-5 py-2.5 rounded-xl text-sm hover:opacity-90" style="background-color:#1B2B5E;">
        + Register Account
    </a>
    <a href="/MIS/UserInformation"
       class="border border-gray-300 text-gray-600 px-5 py-2.5 rounded-xl text-sm hover:bg-gray-50">
        View All Users
    </a>
    <a href="/MIS/ArchivedUsers"
       class="border border-gray-300 text-gray-600 px-5 py-2.5 rounded-xl text-sm hover:bg-gray-50">
        Archived Users
    </a>
</div>

<!-- Recently Added -->
<div class="bg-white rounded-2xl shadow p-6">
    <h2 class="text-lg font-semibold text-gray-700 mb-4">Recently Added Accounts</h2>

    @if (!recentUsers.Any())
    {
        <p class="text-gray-400 text-sm">No accounts yet.</p>
    }
    else
    {
        <table class="w-full text-sm">
            <thead>
                <tr class="text-left text-gray-500 border-b">
                    <th class="pb-2">Name</th>
                    <th class="pb-2">Role</th>
                    <th class="pb-2">Email</th>
                    <th class="pb-2">Status</th>
                    <th class="pb-2">Created</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in recentUsers)
                {
                    <tr class="border-b last:border-0 hover:bg-gray-50">
                        <td class="py-2 font-medium">@u.LastName, @u.FirstName</td>
                        <td class="py-2">
                            <span class="px-2 py-1 rounded-full text-xs
                                @(u.UserType == "Librarian" ? "bg-indigo-100 text-indigo-700" :
                                  u.UserType == "Student"   ? "bg-green-100 text-green-700"   :
                                  "bg-blue-100 text-blue-700")">
                                @u.UserType
                            </span>
                        </td>
                        <td class="py-2 text-gray-500">@u.Email</td>
                        <td class="py-2">
                            @if (u.IsActive)
                            {
                                <span class="bg-green-100 text-green-700 text-xs px-2 py-1 rounded-full">Active</span>
                            }
                            else
                            {
                                <span class="bg-gray-100 text-gray-500 text-xs px-2 py-1 rounded-full">Inactive</span>
                            }
                        </td>
                        <td class="py-2 text-gray-400">@u.CreatedAt.ToString("MMM dd, yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
