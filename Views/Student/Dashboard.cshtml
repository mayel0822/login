@model BookHiveLibrary.Models.ApplicationUser
@{
    ViewData["Title"] = "Student Dashboard";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Student Dashboard - BookHive</title>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
</head>
<body class="bg-gray-100 min-h-screen">

<nav class="bg-violet-700 text-white px-8 py-4 flex items-center justify-between">
    <h1 class="text-2xl font-bold">BookHive</h1>
    <div class="flex items-center gap-6 text-sm">
        <span>Welcome, @(Model?.UserName ?? "Student")</span>
        <a asp-controller="Account" asp-action="Logout"
           class="bg-white text-violet-700 px-4 py-1.5 rounded-lg hover:bg-gray-100 transition">
            Logout
        </a>
    </div>
</nav>

<div class="max-w-5xl mx-auto mt-10 px-6">

    <h2 class="text-3xl font-bold text-gray-800 mb-2">Student Dashboard</h2>
    <p class="text-gray-500 mb-8">Welcome to BookHive Library System</p>

    <div class="grid grid-cols-3 gap-6 mb-10">
        <div class="bg-white rounded-2xl shadow p-6 text-center">
            <div class="text-4xl mb-2">📚</div>
            <div class="text-lg font-semibold text-gray-700">Borrowed Books</div>
            <div class="text-3xl font-bold text-violet-700 mt-1">0</div>
        </div>
        <div class="bg-white rounded-2xl shadow p-6 text-center">
            <div class="text-4xl mb-2">⏰</div>
            <div class="text-lg font-semibold text-gray-700">Due Soon</div>
            <div class="text-3xl font-bold text-amber-500 mt-1">0</div>
        </div>
        <div class="bg-white rounded-2xl shadow p-6 text-center">
            <div class="text-4xl mb-2">✅</div>
            <div class="text-lg font-semibold text-gray-700">Returned</div>
            <div class="text-3xl font-bold text-green-600 mt-1">0</div>
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow p-6">
        <h3 class="text-xl font-semibold text-gray-700 mb-4">My Borrowed Books</h3>
        <p class="text-gray-400 text-center py-8">No borrowed books yet.</p>
    </div>

</div>

</body>
</html>
