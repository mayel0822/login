@using BookHiveLibrary.Models
@model IEnumerable<BookReservation>
@{
    Layout = "~/Views/Shared/_LibrarianLayout.cshtml";
    ViewData["Title"] = "Transaction Management - Book";
    var pending      = ViewBag.PendingReservations as List<BookReservation> ?? new List<BookReservation>();
    var sendReminder = ViewBag.BooksDue            as List<BookReservation> ?? new List<BookReservation>();
    var allDue       = ViewBag.AllBooksDue         as List<BookReservation> ?? new List<BookReservation>();
    var advisers     = ViewBag.SectionAdvisers     as Dictionary<string,string> ?? new Dictionary<string,string>();
}

<div class="grid grid-cols-3 gap-4 mb-6">
    <!-- Pending Reservations Panel -->
    <div class="col-span-1 bg-white rounded-xl shadow-sm border border-gray-100 flex flex-col" style="max-height:420px;">
        <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between flex-shrink-0">
            <h2 class="font-semibold text-gray-700">Pending Reservations</h2>
            <span class="px-2 py-0.5 bg-blue-100 text-blue-700 rounded-full text-xs font-medium">@pending.Count</span>
        </div>

        <!-- RFID Tap Area -->
        <div class="px-4 py-3 border-b border-gray-100 bg-gray-50">
            <p class="text-xs text-gray-400 mb-1">Tap student RFID card to confirm pickup</p>
            <div class="flex items-center gap-2 border border-gray-300 rounded-lg px-3 py-2 bg-white focus-within:ring-2 focus-within:ring-blue-300 cursor-text" onclick="document.getElementById('rfidInput').focus()">
                <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
                </svg>
                <input id="rfidInput" type="text" placeholder="Waiting for RFID tap..."
                       class="text-xs w-full focus:outline-none bg-transparent text-gray-600" autocomplete="off" />
            </div>
            <p id="rfidError" class="text-xs text-red-500 mt-1 hidden"></p>
        </div>
        <div class="flex-1 overflow-y-auto divide-y divide-gray-100">
            @if (!pending.Any())
            {
                <p class="px-5 py-8 text-center text-gray-400 text-sm">No pending reservations</p>
            }
            @foreach (var r in pending)
            {
                var timeLeft = r.PickupDeadline - DateTime.Now;
                var isExpiringSoon = timeLeft.TotalMinutes <= 30 && timeLeft.TotalMinutes > 0;
                var timeDisplay = timeLeft.TotalMinutes > 0
                    ? $"{(int)timeLeft.TotalHours}h {timeLeft.Minutes:D2}m left"
                    : "Expiring...";

                <div class="px-4 py-3 border-b border-gray-50">
                    <div class="flex items-start gap-3">
                        <div class="w-9 h-9 rounded-full bg-blue-100 flex items-center justify-center text-blue-700 text-sm font-bold flex-shrink-0">
                            @r.User?.LastName?.FirstOrDefault()
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-medium text-gray-800">@r.User?.LastName, @r.User?.FirstName @(string.IsNullOrEmpty(r.User?.MiddleName) ? "" : r.User!.MiddleName![0] + ".")</p>
                            @{
                                var sect = r.User?.Section ?? "";
                                var adv  = (!string.IsNullOrEmpty(sect) && advisers.TryGetValue(sect, out var a) && !string.IsNullOrEmpty(a)) ? a : "";
                            }
                            <p class="text-xs text-gray-500">@sect@(adv != "" ? " — " + adv : "")</p>
                            <p class="text-xs text-gray-600 truncate mt-0.5">@r.Book?.Title</p>
                            <span class="text-xs @(isExpiringSoon ? "text-red-500 font-semibold" : "text-gray-400")">@timeDisplay</span>
                        </div>
                    </div>
                    <div class="flex gap-2 mt-2 ml-12">
                        <form method="post" action="@Url.Action("Deny","Borrow")">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@r.Id" />
                            <button type="submit" class="px-3 py-1.5 text-xs border border-red-300 text-red-600 rounded-lg hover:bg-red-50">Deny</button>
                        </form>
                        <form method="post" action="@Url.Action("Approve","Borrow")">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@r.Id" />
                            <button type="submit" class="px-3 py-1.5 text-xs text-white rounded-lg" style="background-color:#1e3a6e;">Grant</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Send Reminder Panel -->
    <div class="col-span-1 bg-white rounded-xl shadow-sm border border-gray-100 flex flex-col" style="max-height:420px;">
        <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between flex-shrink-0">
            <div class="flex items-center gap-2">
                <h2 class="font-semibold text-gray-700">Send Reminder</h2>
                <span class="px-2 py-0.5 bg-yellow-100 text-yellow-700 rounded-full text-xs font-medium">@sendReminder.Count</span>
            </div>
            <form method="post" action="@Url.Action("SendReminder","Borrow")">
                @Html.AntiForgeryToken()
                <button type="submit" class="px-3 py-1.5 text-xs text-white rounded-lg" style="background-color:#1e3a6e;">Send Reminder</button>
            </form>
        </div>
        <div class="flex-1 overflow-y-auto divide-y divide-gray-100">
            @if (!sendReminder.Any())
            {
                <p class="px-5 py-8 text-center text-gray-400 text-sm">No books due within 12 hours</p>
            }
            @foreach (var r in sendReminder)
            {
                var hoursLeft = (r.DueDate - DateTime.Now)?.TotalHours ?? 0;
                <div class="px-4 py-3">
                    <p class="text-sm font-medium text-gray-800">@r.User?.LastName, @r.User?.FirstName</p>
                    <p class="text-xs text-gray-500 truncate">📖 @r.Book?.Title</p>
                    <p class="text-xs @(hoursLeft < 2 ? "text-red-500 font-semibold" : "text-yellow-600") mt-0.5">
                        Due: @r.DueDate?.ToString("MMM dd, hh:mm tt") (@(hoursLeft < 0 ? "Overdue" : $"{(int)hoursLeft}h left"))
                    </p>
                </div>
            }
        </div>
    </div>

    <!-- Books Due Panel -->
    <div class="col-span-1 bg-white rounded-xl shadow-sm border border-gray-100 flex flex-col" style="max-height:420px;">
        <div class="px-5 py-4 border-b border-gray-100 flex-shrink-0">
            <h2 class="font-semibold text-gray-700">Books Due</h2>
            <p class="text-xs text-gray-400 mt-0.5">All active borrows by due date</p>
        </div>
        <div class="flex-1 overflow-y-auto divide-y divide-gray-100">
            @if (!allDue.Any())
            {
                <p class="px-5 py-8 text-center text-gray-400 text-sm">No active borrows</p>
            }
            @{
                var grouped = allDue.GroupBy(r => r.DueDate?.Date ?? DateTime.MinValue).OrderBy(g => g.Key);
            }
            @foreach (var group in grouped)
            {
                <div class="px-4 py-2 bg-gray-50">
                    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">
                        @group.Key.ToString("dddd, MMMM dd")
                        @if (group.Key.Date == DateTime.Today)
                        { <span class="ml-1 text-red-500">(Today)</span> }
                        else if (group.Key.Date == DateTime.Today.AddDays(1))
                        { <span class="ml-1 text-yellow-500">(Tomorrow)</span> }
                    </p>
                </div>
                @foreach (var r in group)
                {
                    var isOverdue = r.DueDate < DateTime.Now;
                    <div class="px-4 py-2.5 hover:bg-gray-50">
                        <p class="text-sm font-medium text-gray-800">@r.User?.LastName, @r.User?.FirstName</p>
                        <p class="text-xs text-gray-500 truncate">@r.Book?.Title</p>
                        @if (isOverdue)
                        {
                            <span class="text-xs text-red-500 font-medium">Overdue</span>
                        }
                    </div>
                }
            }
        </div>
    </div>
</div>

<!-- Borrowed Books Table -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100">
    <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
        <h2 class="font-semibold text-gray-700">Borrowed Books</h2>
        <button onclick="openBorrowModal()"
                class="px-4 py-2 text-sm text-white rounded-lg" style="background-color:#1e3a6e;">+ Borrow Book</button>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 text-gray-500 text-xs uppercase">
                <tr>
                    <th class="px-4 py-3 text-left">Stud ID</th>
                    <th class="px-4 py-3 text-left">Name</th>
                    <th class="px-4 py-3 text-left">Level</th>
                    <th class="px-4 py-3 text-left">Course</th>
                    <th class="px-4 py-3 text-left">Section</th>
                    <th class="px-4 py-3 text-left">Book Title</th>
                    <th class="px-4 py-3 text-left">Borrow Date</th>
                    <th class="px-4 py-3 text-left">Due Date</th>
                    <th class="px-4 py-3 text-left">Status</th>
                    <th class="px-4 py-3 text-left">Action</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @foreach (var r in Model)
                {
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3 text-gray-600 text-xs">@r.User?.StudentNumber</td>
                        <td class="px-4 py-3 font-medium text-gray-800">@r.User?.FirstName @r.User?.LastName</td>
                        <td class="px-4 py-3 text-gray-600">@r.User?.Level</td>
                        <td class="px-4 py-3 text-gray-600">@r.User?.Course</td>
                        <td class="px-4 py-3 text-gray-600">@r.User?.Section</td>
                        <td class="px-4 py-3 text-gray-700">@r.Book?.Title</td>
                        <td class="px-4 py-3 text-gray-500 text-xs">@r.ActualPickupTime?.ToString("MM/dd/yyyy")</td>
                        <td class="px-4 py-3 text-gray-500 text-xs">@r.DueDate?.ToString("MM/dd/yyyy")</td>
                        <td class="px-4 py-3">
                            @{
                                var badgeClass = r.Status switch {
                                    "Overdue" => "bg-red-100 text-red-700",
                                    "PickedUp" => "bg-green-100 text-green-700",
                                    "Approved" => "bg-blue-100 text-blue-700",
                                    _ => "bg-gray-100 text-gray-600"
                                };
                                var label = r.Status == "PickedUp" ? "Active" : r.Status;
                            }
                            <span class="px-2 py-1 rounded-full text-xs font-medium @badgeClass">@label</span>
                        </td>
                        <td class="px-4 py-3">
                            @if (r.Status == "Approved")
                            {
                                <form method="post" action="@Url.Action("ConfirmPickup","Borrow")" class="inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@r.Id" />
                                    <button type="submit" class="text-xs px-3 py-1.5 text-white rounded" style="background-color:#1e3a6e;">Pickup</button>
                                </form>
                            }
                            else if (r.Status == "PickedUp" || r.Status == "Overdue")
                            {
                                <form method="post" action="@Url.Action("ConfirmReturn","Borrow")" class="inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@r.Id" />
                                    <button type="submit" class="text-xs px-3 py-1.5 border border-gray-300 text-gray-600 rounded hover:bg-gray-50">Return</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="10" class="px-4 py-8 text-center text-gray-400">No borrowed books yet. Use <strong>+ Borrow Book</strong> to record a walk-up borrow.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Borrow Slip Modal (RFID pickup confirmation) -->
<div id="borrowSlipModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-xl w-[480px] shadow-xl overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between" style="background-color:#1e3a6e;">
            <h3 class="text-base font-semibold text-white">Borrow Slip — Pickup Confirmation</h3>
            <button onclick="closeSlip()" class="text-white/70 hover:text-white">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>
        <div class="px-6 py-5">
            <div class="grid grid-cols-2 gap-x-6 gap-y-3 text-sm mb-5">
                <div>
                    <p class="text-xs text-gray-400 mb-0.5">Student / Employee No.</p>
                    <p id="slipStudentNo" class="font-medium text-gray-800"></p>
                </div>
                <div>
                    <p class="text-xs text-gray-400 mb-0.5">Name</p>
                    <p id="slipName" class="font-medium text-gray-800"></p>
                </div>
                <div>
                    <p class="text-xs text-gray-400 mb-0.5">Section</p>
                    <p id="slipSection" class="font-medium text-gray-800"></p>
                </div>
                <div>
                    <p class="text-xs text-gray-400 mb-0.5">Course / Level</p>
                    <p id="slipCourse" class="font-medium text-gray-800"></p>
                </div>
                <div class="col-span-2 border-t border-gray-100 pt-3">
                    <p class="text-xs text-gray-400 mb-0.5">Book Title</p>
                    <p id="slipBook" class="font-semibold text-gray-800"></p>
                    <p id="slipAuthor" class="text-xs text-gray-500"></p>
                </div>
                <div>
                    <p class="text-xs text-gray-400 mb-0.5">Reserved At</p>
                    <p id="slipReservedAt" class="text-gray-600"></p>
                </div>
                <div>
                    <p class="text-xs text-gray-400 mb-0.5">Time Remaining</p>
                    <p id="slipTimeLeft" class="text-gray-600"></p>
                </div>
            </div>
            <form method="post" action="@Url.Action("Approve","Borrow")">
                @Html.AntiForgeryToken()
                <input type="hidden" id="slipReservationId" name="id" value="" />
                <div class="flex gap-3">
                    <button type="button" onclick="closeSlip()"
                            class="flex-1 py-2.5 bg-gray-100 text-gray-700 rounded-lg text-sm hover:bg-gray-200">Cancel</button>
                    <button type="submit"
                            class="flex-1 py-2.5 text-white rounded-lg text-sm font-medium" style="background-color:#1e3a6e;">
                        Confirm Pickup
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Borrow Book Modal -->
<div id="borrowModal" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 hidden">
    <div class="bg-white rounded-xl shadow-xl w-[520px] overflow-hidden">

        <!-- Header -->
        <div class="px-6 py-4 flex items-center justify-between" style="background-color:#1e3a6e;">
            <div>
                <h3 class="text-base font-semibold text-white">Borrow Slip</h3>
                <p class="text-xs text-white/60 mt-0.5">Walk-in Borrow Record</p>
            </div>
            <button type="button" onclick="closeBorrowModal()" class="text-white/60 hover:text-white">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <form method="post" action="@Url.Action("CreateBorrow","Borrow")" id="borrowForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="userId" id="borrowUserId" />

            <div class="px-6 pt-5 pb-4">

                <!-- Step 1: User Type + Identifier -->
                <div class="flex gap-3 mb-5">
                    <div class="w-40 flex-shrink-0">
                        <p class="text-xs text-gray-400 mb-1">User Type</p>
                        <select id="borrowUserType" onchange="onBorrowTypeChange()"
                                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300">
                            <option value="">Select...</option>
                            <option value="Student">Student</option>
                            <option value="Professor">Professor</option>
                        </select>
                    </div>
                    <!-- Student: RFID -->
                    <div id="rfidBorrowArea" class="hidden flex-1">
                        <p class="text-xs text-gray-400 mb-1">RFID Card</p>
                        <div class="flex items-center gap-2 border border-gray-300 rounded-lg px-3 py-2 bg-gray-50 focus-within:ring-2 focus-within:ring-blue-300 cursor-text"
                             onclick="document.getElementById('borrowRfidInput').focus()">
                            <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
                            </svg>
                            <input id="borrowRfidInput" type="text" placeholder="Tap card..."
                                   class="text-sm w-full focus:outline-none bg-transparent text-gray-700" autocomplete="off" />
                        </div>
                        <p id="borrowRfidError" class="text-xs text-red-500 mt-1 hidden"></p>
                    </div>
                    <!-- Professor: search -->
                    <div id="professorSelectArea" class="hidden flex-1">
                        <p class="text-xs text-gray-400 mb-1">Employee No. / Name</p>
                        <input id="professorSearch" type="text" placeholder="Type to search..."
                               oninput="onProfessorSearch()"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300" autocomplete="off" />
                        <div id="professorDropdown" class="hidden absolute z-50 bg-white border border-gray-200 rounded-lg shadow-lg mt-1 max-h-40 overflow-y-auto w-64"></div>
                    </div>
                </div>

                <!-- Divider -->
                <div class="border-t border-dashed border-gray-200 mb-4"></div>

                <!-- Slip Fields -->
                <div class="grid grid-cols-2 gap-x-6 gap-y-4 text-sm">
                    <div>
                        <p class="text-xs text-gray-400 mb-0.5">Last Name</p>
                        <p id="infoLastName" class="font-medium text-gray-800 min-h-[1.25rem] border-b border-gray-200 pb-1 hidden">—</p>
                        <input id="inputLastName" type="text" placeholder="Last name"
                               class="w-full border-b border-gray-300 py-1 text-sm font-medium text-gray-800 focus:outline-none focus:border-blue-400 bg-transparent hidden" />
                    </div>
                    <div>
                        <p class="text-xs text-gray-400 mb-0.5">First Name</p>
                        <p id="infoFirstName" class="font-medium text-gray-800 min-h-[1.25rem] border-b border-gray-200 pb-1 hidden">—</p>
                        <input id="inputFirstName" type="text" placeholder="First name"
                               class="w-full border-b border-gray-300 py-1 text-sm font-medium text-gray-800 focus:outline-none focus:border-blue-400 bg-transparent hidden" />
                    </div>
                    <div>
                        <p class="text-xs text-gray-400 mb-0.5">M.I.</p>
                        <p id="infoMI" class="font-medium text-gray-800 min-h-[1.25rem] border-b border-gray-200 pb-1 hidden">—</p>
                        <input id="inputMI" type="text" placeholder="M.I." maxlength="2"
                               class="w-full border-b border-gray-300 py-1 text-sm font-medium text-gray-800 focus:outline-none focus:border-blue-400 bg-transparent hidden" />
                    </div>
                    <div>
                        <p class="text-xs text-gray-400 mb-0.5">Section</p>
                        <p id="infoSection" class="font-medium text-gray-800 min-h-[1.25rem] border-b border-gray-200 pb-1 hidden">—</p>
                        <input id="inputSection" type="text" placeholder="Section"
                               class="w-full border-b border-gray-300 py-1 text-sm font-medium text-gray-800 focus:outline-none focus:border-blue-400 bg-transparent hidden" />
                    </div>
                    <div class="col-span-2">
                        <p class="text-xs text-gray-400 mb-0.5">Adviser</p>
                        <p id="infoAdviser" class="font-medium text-gray-800 min-h-[1.25rem] border-b border-gray-200 pb-1 hidden">—</p>
                        <input id="inputAdviser" type="text" placeholder="Adviser name"
                               class="w-full border-b border-gray-300 py-1 text-sm font-medium text-gray-800 focus:outline-none focus:border-blue-400 bg-transparent hidden" />
                    </div>
                </div>

                <!-- Book selector -->
                <div class="mt-4">
                    <p class="text-xs text-gray-400 mb-1">Book Title</p>
                    <select name="bookId" id="borrowBookSelect" required
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300">
                        <option value="">Select book to borrow...</option>
                        @if (ViewBag.AvailableBooks != null)
                        {
                            foreach (var b in (List<BookHiveLibrary.Models.Book>)ViewBag.AvailableBooks)
                            {
                                <option value="@b.Id">@b.Title — @b.Author (@b.AvailableQuantity avail.)</option>
                            }
                        }
                    </select>
                </div>

                <!-- Due date info -->
                <div class="mt-3 flex items-center gap-2 text-xs text-gray-400">
                    <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    Due in 2 days at 4:30 PM
                </div>
            </div>

            <!-- Footer -->
            <div class="px-6 py-4 border-t border-gray-100 flex gap-3">
                <button type="button" onclick="closeBorrowModal()"
                        class="flex-1 py-2.5 bg-gray-100 text-gray-700 rounded-lg text-sm hover:bg-gray-200">Cancel</button>
                <button type="submit" id="borrowSubmitBtn" disabled
                        class="flex-1 py-2.5 text-white rounded-lg text-sm font-medium opacity-50 cursor-not-allowed" style="background-color:#1e3a6e;">
                    Confirm Borrow
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
const rfidInput = document.getElementById('rfidInput');
const rfidError = document.getElementById('rfidError');
let rfidBuffer = '';
let rfidTimer = null;

// RFID readers type characters rapidly then send Enter
rfidInput.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') {
        e.preventDefault();
        const rfid = rfidBuffer.trim();
        rfidBuffer = '';
        if (rfid) lookupRfid(rfid);
    }
});

rfidInput.addEventListener('input', function() {
    rfidBuffer = this.value;
    clearTimeout(rfidTimer);
    // Auto-submit after 100ms of no input (fast reader)
    rfidTimer = setTimeout(() => {
        const rfid = rfidBuffer.trim();
        rfidBuffer = '';
        rfidInput.value = '';
        if (rfid.length >= 4) lookupRfid(rfid);
    }, 200);
});

async function lookupRfid(rfid) {
    rfidInput.value = '';
    rfidError.classList.add('hidden');
    rfidInput.placeholder = 'Looking up...';

    try {
        const res = await fetch(`@Url.Action("FindByRfid","Borrow")?rfid=${encodeURIComponent(rfid)}`);
        const data = await res.json();

        if (!data.found) {
            rfidError.textContent = data.message;
            rfidError.classList.remove('hidden');
            rfidInput.placeholder = 'Waiting for RFID tap...';
            return;
        }

        // Fill borrow slip
        document.getElementById('slipStudentNo').textContent  = data.studentNumber  || '—';
        document.getElementById('slipName').textContent       = data.fullName        || '—';
        document.getElementById('slipSection').textContent    = data.section         || '—';
        document.getElementById('slipCourse').textContent     = [data.course, data.level].filter(Boolean).join(' · ') || '—';
        document.getElementById('slipBook').textContent       = data.bookTitle       || '—';
        document.getElementById('slipAuthor').textContent     = data.bookAuthor      || '';
        document.getElementById('slipReservedAt').textContent = data.reservedAt      || '—';
        document.getElementById('slipTimeLeft').textContent   = data.timeLeft        || '—';
        document.getElementById('slipReservationId').value    = data.reservationId;

        document.getElementById('borrowSlipModal').classList.remove('hidden');
    } catch {
        rfidError.textContent = 'Error communicating with server.';
        rfidError.classList.remove('hidden');
    }

    rfidInput.placeholder = 'Waiting for RFID tap...';
}

function closeSlip() {
    document.getElementById('borrowSlipModal').classList.add('hidden');
    rfidInput.focus();
}

// Keep RFID input always ready
document.addEventListener('click', function(e) {
    if (!e.target.closest('#borrowSlipModal') && !e.target.closest('#borrowModal')) {
        rfidInput.focus();
    }
});
rfidInput.focus();

// ── Walk-in Borrow Modal ──────────────────────────────────────────────────────

let borrowRfidBuffer = '';
let borrowRfidTimer  = null;
let currentBorrowType = '';

// Professor data for search
const professorData = [
    @if (ViewBag.Students != null)
    {
        foreach (var u in (List<BookHiveLibrary.Models.ApplicationUser>)ViewBag.Students)
        {
            if (u.UserType == "Professor")
            {
                @Html.Raw($"{{ id:'{u.Id}', ln:'{u.LastName?.Replace("'","\\'")}', fn:'{u.FirstName?.Replace("'","\\'")}', mn:'{(u.MiddleName ?? "").Replace("'","\\'")}', section:'{(u.Section ?? "").Replace("'","\\'")}', empno:'{(u.EmployeeNumber ?? "").Replace("'","\\'")}' }},")
            }
        }
    }
];

function openBorrowModal() {
    resetBorrowModal();
    document.getElementById('borrowModal').classList.remove('hidden');
}

function closeBorrowModal() {
    document.getElementById('borrowModal').classList.add('hidden');
    resetBorrowModal();
    rfidInput.focus();
}

function resetBorrowModal() {
    currentBorrowType = '';
    document.getElementById('borrowUserType').value = '';
    document.getElementById('borrowUserId').value = '';
    document.getElementById('rfidBorrowArea').classList.add('hidden');
    document.getElementById('professorSelectArea').classList.add('hidden');
    document.getElementById('borrowBookSelect').value = '';
    document.getElementById('borrowSubmitBtn').disabled = true;
    document.getElementById('borrowSubmitBtn').classList.add('opacity-50', 'cursor-not-allowed');
    const errEl = document.getElementById('borrowRfidError');
    if (errEl) { errEl.textContent = ''; errEl.classList.add('hidden'); }
    showSlipFields(false);
    clearBorrowerInfo();
}

function showSlipFields(show) {
    // Display elements (student)
    ['infoLastName','infoFirstName','infoMI','infoSection','infoAdviser'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.classList.toggle('hidden', !show || currentBorrowType !== 'Student');
    });
    // Input elements (professor)
    ['inputLastName','inputFirstName','inputMI','inputSection','inputAdviser'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.classList.toggle('hidden', !show || currentBorrowType !== 'Professor');
    });
}

function onBorrowTypeChange() {
    currentBorrowType = document.getElementById('borrowUserType').value;
    document.getElementById('rfidBorrowArea').classList.toggle('hidden', currentBorrowType !== 'Student');
    document.getElementById('professorSelectArea').classList.toggle('hidden', currentBorrowType !== 'Professor');
    document.getElementById('borrowUserId').value = '';
    document.getElementById('borrowSubmitBtn').disabled = true;
    document.getElementById('borrowSubmitBtn').classList.add('opacity-50', 'cursor-not-allowed');
    clearBorrowerInfo();

    if (currentBorrowType === 'Student') {
        showSlipFields(false); // will show after RFID tap
        setTimeout(() => document.getElementById('borrowRfidInput')?.focus(), 50);
    } else if (currentBorrowType === 'Professor') {
        // Show manual input fields immediately
        showSlipFields(true);
        // Professor: enable submit when they start typing — watch inputs
        enableSubmitOnProfessorInput();
    } else {
        showSlipFields(false);
    }
}

function enableSubmitOnProfessorInput() {
    const btn = document.getElementById('borrowSubmitBtn');
    ['inputLastName','inputFirstName'].forEach(id => {
        const el = document.getElementById(id);
        if (el) {
            el.oninput = () => {
                const ln = document.getElementById('inputLastName').value.trim();
                const fn = document.getElementById('inputFirstName').value.trim();
                btn.disabled = !(ln && fn);
                btn.classList.toggle('opacity-50', btn.disabled);
                btn.classList.toggle('cursor-not-allowed', btn.disabled);
            };
        }
    });
}

function clearBorrowerInfo() {
    ['infoLastName','infoFirstName','infoMI','infoSection','infoAdviser'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.textContent = '—';
    });
    ['inputLastName','inputFirstName','inputMI','inputSection','inputAdviser'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.value = '';
    });
}

function fillBorrowerInfo(data) {
    document.getElementById('infoLastName').textContent  = data.lastName   || '—';
    document.getElementById('infoFirstName').textContent = data.firstName  || '—';
    document.getElementById('infoMI').textContent        = data.middleName ? data.middleName[0] + '.' : '—';
    document.getElementById('infoSection').textContent   = data.section    || '—';
    document.getElementById('infoAdviser').textContent   = data.adviserName || '—';
    document.getElementById('borrowUserId').value        = data.userId || '';
    showSlipFields(true);
    document.getElementById('borrowSubmitBtn').disabled = false;
    document.getElementById('borrowSubmitBtn').classList.remove('opacity-50', 'cursor-not-allowed');
}

// RFID for students
const borrowRfidInputEl = document.getElementById('borrowRfidInput');
if (borrowRfidInputEl) {
    borrowRfidInputEl.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            const rfid = borrowRfidBuffer.trim();
            borrowRfidBuffer = '';
            if (rfid) lookupBorrowRfid(rfid);
        }
    });
    borrowRfidInputEl.addEventListener('input', function() {
        borrowRfidBuffer = this.value;
        clearTimeout(borrowRfidTimer);
        borrowRfidTimer = setTimeout(() => {
            const rfid = borrowRfidBuffer.trim();
            borrowRfidBuffer = '';
            borrowRfidInputEl.value = '';
            if (rfid.length >= 4) lookupBorrowRfid(rfid);
        }, 200);
    });
}

async function lookupBorrowRfid(rfid) {
    const errEl = document.getElementById('borrowRfidError');
    if (errEl) errEl.classList.add('hidden');
    if (borrowRfidInputEl) borrowRfidInputEl.placeholder = 'Looking up...';

    try {
        const res = await fetch(`@Url.Action("FindUserByRfid","Borrow")?rfid=${encodeURIComponent(rfid)}`);
        const data = await res.json();
        if (!data.found) {
            if (errEl) { errEl.textContent = data.message; errEl.classList.remove('hidden'); }
        } else {
            fillBorrowerInfo(data);
        }
    } catch {
        if (errEl) { errEl.textContent = 'Error communicating with server.'; errEl.classList.remove('hidden'); }
    }
    if (borrowRfidInputEl) borrowRfidInputEl.placeholder = 'Tap card...';
}

// Professor search
function onProfessorSearch() {
    const q = document.getElementById('professorSearch').value.toLowerCase().trim();
    const dd = document.getElementById('professorDropdown');
    if (!q) { dd.classList.add('hidden'); return; }

    const matches = professorData.filter(p =>
        (p.ln + ' ' + p.fn + ' ' + p.empno).toLowerCase().includes(q)
    ).slice(0, 8);

    if (!matches.length) { dd.classList.add('hidden'); return; }

    dd.innerHTML = matches.map(p => `
        <div class="px-3 py-2 text-sm text-gray-700 hover:bg-blue-50 cursor-pointer"
             onclick="selectProfessor('${p.id}','${p.ln}','${p.fn}','${p.mn}','${p.section}')">
            ${p.ln}, ${p.fn} <span class="text-gray-400 text-xs">${p.empno}</span>
        </div>`).join('');
    dd.classList.remove('hidden');
}

function selectProfessor(id, ln, fn, mn, section) {
    document.getElementById('professorSearch').value = ln + ', ' + fn;
    document.getElementById('professorDropdown').classList.add('hidden');
    document.getElementById('inputLastName').value  = ln;
    document.getElementById('inputFirstName').value = fn;
    document.getElementById('inputMI').value        = mn ? mn[0] : '';
    document.getElementById('inputSection').value   = section;
    document.getElementById('borrowUserId').value   = id;
    const btn = document.getElementById('borrowSubmitBtn');
    btn.disabled = false;
    btn.classList.remove('opacity-50', 'cursor-not-allowed');
}

// Close professor dropdown on outside click
document.addEventListener('click', function(e) {
    if (!e.target.closest('#professorSelectArea')) {
        document.getElementById('professorDropdown')?.classList.add('hidden');
    }
});
</script>
}
