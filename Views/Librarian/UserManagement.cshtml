@using BookHiveLibrary.Models
@model IEnumerable<ApplicationUser>
@{
    Layout = "~/Views/Shared/_LibrarianLayout.cshtml";
    ViewData["Title"] = "User Management";
}

<div class="bg-white rounded-xl shadow-sm border border-gray-100">
    <!-- Header with search and filter -->
    <div class="px-5 py-4 border-b border-gray-100 flex flex-wrap gap-3 items-center justify-between">
        <h2 class="font-semibold text-gray-700">Users</h2>
        <div class="flex gap-3 items-center">
            <form method="get" class="flex items-center border border-gray-300 rounded-full overflow-hidden shadow-sm bg-white">
                <!-- Dropdown filter -->
                <select name="userType"
                        class="text-sm text-gray-600 px-3 py-2 bg-gray-50 border-r border-gray-300 focus:outline-none">
                    <option value="">All Users</option>
                    <option value="Student" selected="@(ViewBag.UserType == "Student" ? "selected" : null)">Students</option>
                    <option value="Professor" selected="@(ViewBag.UserType == "Professor" ? "selected" : null)">Professors</option>
                </select>
                <!-- Search input -->
                <input type="text" name="search" value="@ViewBag.Search"
                       placeholder="Search by name, ID, email..."
                       class="text-sm px-4 py-2 w-64 focus:outline-none bg-white" />
                <!-- Search button with icon -->
                <button type="submit" class="px-4 py-2 flex items-center justify-center bg-white hover:bg-gray-50">
                    <svg class="w-4 h-4" fill="none" stroke="#1e3a6e" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
                    </svg>
                </button>
            </form>
            <a href="@Url.Action("Registration","Librarian")"
               class="px-4 py-2 text-sm text-white rounded-full" style="background-color:#1e3a6e;">+ Add User</a>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 text-gray-500 text-xs uppercase">
                <tr>
                    <th class="px-4 py-3 text-left">Stud/Emp ID</th>
                    <th class="px-4 py-3 text-left">Name</th>
                    <th class="px-4 py-3 text-left">Email</th>
                    <th class="px-4 py-3 text-left">Phone</th>
                    <th class="px-4 py-3 text-left">Type</th>
                    <th class="px-4 py-3 text-left">Status</th>
                    <th class="px-4 py-3 text-left"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @foreach (var user in Model)
                {
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3 text-gray-600">
                            @(user.UserType == "Student" ? user.StudentNumber : user.EmployeeNumber)
                        </td>
                        <td class="px-4 py-3 font-medium text-gray-800">@user.LastName, @user.FirstName @(string.IsNullOrEmpty(user.MiddleName) ? "" : user.MiddleName[0] + ".")</td>
                        <td class="px-4 py-3 text-gray-600">@user.Email</td>
                        <td class="px-4 py-3 text-gray-600">@user.PhoneNumber</td>
                        <td class="px-4 py-3">
                            <span class="px-2 py-1 rounded-full text-xs font-medium @(user.UserType == "Student" ? "bg-blue-100 text-blue-700" : "bg-purple-100 text-purple-700")">
                                @user.UserType
                            </span>
                        </td>
                        <td class="px-4 py-3">
                            @if (user.IsActive)
                            {
                                <span class="px-2 py-1 bg-green-100 text-green-700 rounded-full text-xs font-medium">Active</span>
                            }
                            else
                            {
                                <span class="px-2 py-1 bg-red-100 text-red-700 rounded-full text-xs font-medium">Inactive</span>
                            }
                        </td>
                        <td class="px-4 py-3">
                            <div class="flex gap-2">
                                <form method="post" action="@Url.Action("ToggleAccountStatus","Librarian")">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit"
                                            class="text-xs px-3 py-1.5 rounded border @(user.IsActive ? "border-red-300 text-red-600 hover:bg-red-50" : "border-green-300 text-green-600 hover:bg-green-50")">
                                        @(user.IsActive ? "Deactivate" : "Activate")
                                    </button>
                                </form>
                                <a href="#" class="text-gray-400 hover:text-gray-600">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="px-4 py-8 text-center text-gray-400">No users found</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
