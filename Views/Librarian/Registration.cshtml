@{
    Layout = "~/Views/Shared/_LibrarianLayout.cshtml";
    ViewData["Title"] = "User Registration";
}

@if (TempData["Error"] != null)
{
    <div class="bg-red-50 border border-red-300 text-red-700 text-sm px-4 py-3 rounded-lg mb-4">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="bg-green-50 border border-green-300 text-green-700 text-sm px-4 py-3 rounded-lg mb-4">@TempData["Success"]</div>
}

<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">

    <!-- Header -->
    <div class="flex items-center justify-between mb-5">
        <div>
            <h2 class="text-lg font-semibold text-gray-700">Register New User</h2>
            <p class="text-sm text-gray-400">Select user type to begin.</p>
        </div>
        <!-- Import Excel Button -->
        <button onclick="document.getElementById('importModal').classList.remove('hidden')"
                class="flex items-center gap-2 px-4 py-2 text-sm text-white rounded-lg" style="background-color:#1e3a6e;">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3"/>
            </svg>
            Import Excel
        </button>
    </div>

    <form method="post" action="@Url.Action("Registration","Librarian")" id="regForm">
        @Html.AntiForgeryToken()

        <!-- User Type -->
        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-600 mb-1">User Type</label>
            <select name="userType" id="userType" required onchange="onTypeChange()"
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300">
                <option value="">Select type...</option>
                <option value="Student">Student</option>
                <option value="Professor">Professor</option>
            </select>
        </div>

        <!-- Fields (hidden until type selected) -->
        <div id="formFields" class="hidden">

            <!-- Email dropdown from MIS -->
            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-600 mb-1">School Email (from MIS)</label>
                <select name="email" id="emailSelect" required onchange="onEmailChange()"
                        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300">
                    <option value="">Select account...</option>
                </select>
            </div>

            <!-- Name fields -->
            <div class="grid grid-cols-3 gap-3 mb-4">
                <div>
                    <label class="block text-sm font-medium text-gray-600 mb-1">First Name</label>
                    <input type="text" name="firstName" id="firstName" required
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300 bg-gray-50" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-600 mb-1">Middle Name</label>
                    <input type="text" name="middleName" id="middleName"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300 bg-gray-50" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-600 mb-1">Last Name</label>
                    <input type="text" name="lastName" id="lastName" required
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300 bg-gray-50" />
                </div>
            </div>

            <div class="grid grid-cols-2 gap-3 mb-4">
                <div id="studentNumField">
                    <label class="block text-sm font-medium text-gray-600 mb-1">Student Number</label>
                    <input type="text" name="studentNumber" id="studentNumber"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300 bg-gray-50" />
                </div>
                <div id="employeeNumField" class="hidden">
                    <label class="block text-sm font-medium text-gray-600 mb-1">Employee Number</label>
                    <input type="text" name="employeeNumber" id="employeeNumber"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300 bg-gray-50" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-600 mb-1">Phone Number</label>
                    <input type="tel" name="phoneNumber" id="phoneNumber"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300 bg-gray-50" />
                </div>
            </div>

            <div class="mb-6">
                <label class="block text-sm font-medium text-gray-600 mb-1">Section / Department</label>
                <input type="text" name="section" id="section"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300 bg-gray-50" />
            </div>

            <!-- Buttons right-aligned -->
            <div class="flex gap-3 justify-end">
                <a href="@Url.Action("UserManagement","Librarian")" class="px-6 py-2 bg-gray-100 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-200">Cancel</a>
                <button type="submit" class="px-6 py-2 text-white rounded-lg text-sm font-medium" style="background-color:#1e3a6e;">Register</button>
            </div>
        </div>
    </form>
</div>

<!-- Import Excel Modal -->
<div id="importModal" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 hidden">
    <div class="bg-white rounded-xl p-6 w-[600px] shadow-xl">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold text-gray-700">Import from Excel</h3>
            <button onclick="document.getElementById('importModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <form method="post" action="@Url.Action("ImportExcel","Librarian")" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="border-2 border-dashed border-gray-300 rounded-xl p-6 text-center mb-4 hover:border-blue-400 transition">
                <svg class="w-10 h-10 mx-auto text-gray-300 mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                <p class="text-sm text-gray-400 mb-2">Drag & drop your Excel file here or</p>
                <label class="cursor-pointer text-sm font-medium text-blue-600 hover:underline">
                    Browse file
                    <input type="file" name="file" accept=".xlsx,.xls" class="hidden" id="excelFile" onchange="showFileName(this)" required />
                </label>
                <p class="text-xs text-gray-400 mt-1" id="fileName">No file selected</p>
            </div>
            <div class="flex gap-3 justify-end">
                <button type="button" onclick="document.getElementById('importModal').classList.add('hidden')"
                        class="px-5 py-2 bg-gray-100 text-gray-700 rounded-lg text-sm hover:bg-gray-200">Cancel</button>
                <button type="submit" class="px-5 py-2 text-white rounded-lg text-sm font-medium" style="background-color:#1e3a6e;">Import Users</button>
            </div>
        </form>
    </div>
</div>

<!-- Import Results Table -->
@if (ViewBag.ImportedUsers != null)
{
    var imported = ViewBag.ImportedUsers as List<string[]>;
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mt-6">
        <h3 class="text-sm font-semibold text-gray-700 mb-3">Import Results — @imported.Count row(s) processed</h3>
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead class="bg-gray-50 text-gray-500 text-xs uppercase">
                    <tr>
                        <th class="px-4 py-3 text-left">Type</th>
                        <th class="px-4 py-3 text-left">Name</th>
                        <th class="px-4 py-3 text-left">Email</th>
                        <th class="px-4 py-3 text-left">ID</th>
                        <th class="px-4 py-3 text-left">Section</th>
                        <th class="px-4 py-3 text-left">Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var row in imported)
                    {
                        <tr class="hover:bg-gray-50">
                            <td class="px-4 py-3 text-gray-600">@row[0]</td>
                            <td class="px-4 py-3 font-medium text-gray-800">@row[1]</td>
                            <td class="px-4 py-3 text-gray-600">@row[2]</td>
                            <td class="px-4 py-3 text-gray-600">@row[3]</td>
                            <td class="px-4 py-3 text-gray-600">@row[4]</td>
                            <td class="px-4 py-3">
                                <span class="px-2 py-1 rounded-full text-xs font-medium @(row[5] == "Registered" ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700")">
                                    @row[5]
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
<script>
const students = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(
    (ViewBag.Students as List<BookHiveLibrary.Models.ApplicationUser> ?? new List<BookHiveLibrary.Models.ApplicationUser>())
    .Select(u => new { u.Email, u.FirstName, u.MiddleName, u.LastName, u.StudentNumber, u.EmployeeNumber, u.PhoneNumber, u.Section })
));
const professors = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(
    (ViewBag.Professors as List<BookHiveLibrary.Models.ApplicationUser> ?? new List<BookHiveLibrary.Models.ApplicationUser>())
    .Select(u => new { u.Email, u.FirstName, u.MiddleName, u.LastName, u.StudentNumber, u.EmployeeNumber, u.PhoneNumber, u.Section })
));

function onTypeChange() {
    const type = document.getElementById('userType').value;
    const fields = document.getElementById('formFields');
    const emailSelect = document.getElementById('emailSelect');
    const studentNumField = document.getElementById('studentNumField');
    const employeeNumField = document.getElementById('employeeNumField');

    if (!type) { fields.classList.add('hidden'); return; }
    fields.classList.remove('hidden');

    if (type === 'Student') {
        studentNumField.classList.remove('hidden');
        employeeNumField.classList.add('hidden');
    } else {
        studentNumField.classList.add('hidden');
        employeeNumField.classList.remove('hidden');
    }

    const users = type === 'Student' ? students : professors;
    emailSelect.innerHTML = '<option value="">Select account...</option>';
    users.forEach(u => {
        const opt = document.createElement('option');
        opt.value = u.Email;
        opt.textContent = `${u.LastName}, ${u.FirstName} — ${u.Email}`;
        opt.dataset.user = JSON.stringify(u);
        emailSelect.appendChild(opt);
    });

    clearFields();
}

function onEmailChange() {
    const select = document.getElementById('emailSelect');
    const opt = select.selectedOptions[0];
    if (!opt || !opt.dataset.user) { clearFields(); return; }
    const u = JSON.parse(opt.dataset.user);
    document.getElementById('firstName').value      = u.FirstName      ?? '';
    document.getElementById('middleName').value     = u.MiddleName     ?? '';
    document.getElementById('lastName').value       = u.LastName       ?? '';
    document.getElementById('studentNumber').value  = u.StudentNumber  ?? '';
    document.getElementById('employeeNumber').value = u.EmployeeNumber ?? '';
    document.getElementById('phoneNumber').value    = u.PhoneNumber    ?? '';
    document.getElementById('section').value        = u.Section        ?? '';
}

function clearFields() {
    ['firstName','middleName','lastName','studentNumber','employeeNumber','phoneNumber','section']
        .forEach(id => { const el = document.getElementById(id); if (el) el.value = ''; });
}

function showFileName(input) {
    document.getElementById('fileName').textContent = input.files[0]?.name ?? 'No file selected';
}
</script>
}
