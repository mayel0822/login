<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookHive Library</title>
    <link rel="stylesheet" href="~/css/output.css" />
</head>
<body class="bg-gray-100 flex h-screen overflow-hidden">

<!-- Sidebar -->
<aside class="flex flex-col w-64 min-h-screen text-white flex-shrink-0" style="background-color:#1e3a6e;">
    <!-- Logo -->
    <div class="flex items-center gap-3 px-6 py-5 border-b border-blue-800">
        <div class="w-10 h-10 rounded-full bg-yellow-400 flex items-center justify-center font-bold text-blue-900 text-lg">B</div>
        <span class="text-xl font-bold tracking-wide">BookHive</span>
    </div>

    <!-- Nav -->
    <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">

        <!-- Home / Dashboard -->
        <a href="@Url.Action("Dashboard","Librarian")"
           class="flex items-center gap-3 px-4 py-2.5 rounded-lg hover:bg-blue-800 transition @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" && ViewContext.RouteData.Values["controller"]?.ToString() == "Librarian" ? "bg-blue-800 font-semibold" : "")">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0h6"/></svg>
            <span>Home</span>
        </a>

        <!-- User Management -->
        @{
            var isUserMgmt = new[] { "UserManagement", "Registration", "Sectioning", "StudentActivity" }
                .Contains(ViewContext.RouteData.Values["action"]?.ToString());
        }
        <div>
            <button onclick="toggleMenu('userMgmtMenu', this)"
                    class="w-full flex items-center gap-3 px-4 py-2.5 rounded-lg hover:bg-blue-800 transition @(isUserMgmt ? "bg-blue-800 font-semibold" : "")">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <span class="flex-1 text-left">User Management</span>
                <svg id="userMgmtArrow" class="w-4 h-4 transition-transform @(isUserMgmt ? "rotate-180" : "")" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div id="userMgmtMenu" class="mt-1 ml-8 space-y-1 @(isUserMgmt ? "" : "hidden")">
                <a href="@Url.Action("UserManagement","Librarian")" class="block px-3 py-2 rounded-lg text-sm text-blue-200 hover:bg-blue-800 hover:text-white transition @(ViewContext.RouteData.Values["action"]?.ToString() == "UserManagement" ? "text-white font-medium" : "")">Users</a>
                <a href="@Url.Action("Registration","Librarian")" class="block px-3 py-2 rounded-lg text-sm text-blue-200 hover:bg-blue-800 hover:text-white transition @(ViewContext.RouteData.Values["action"]?.ToString() == "Registration" ? "text-white font-medium" : "")">Registration</a>
                <a href="@Url.Action("Sectioning","Librarian")" class="block px-3 py-2 rounded-lg text-sm text-blue-200 hover:bg-blue-800 hover:text-white transition @(ViewContext.RouteData.Values["action"]?.ToString() == "Sectioning" ? "text-white font-medium" : "")">Sectioning</a>
                <a href="@Url.Action("StudentActivity","Librarian")" class="block px-3 py-2 rounded-lg text-sm text-blue-200 hover:bg-blue-800 hover:text-white transition @(ViewContext.RouteData.Values["action"]?.ToString() == "StudentActivity" ? "text-white font-medium" : "")">Activity</a>
            </div>
        </div>

        <!-- Transaction Activity -->
        @{
            var isTransaction = new[] { "Borrow", "Computer" }.Contains(ViewContext.RouteData.Values["controller"]?.ToString());
        }
        <div>
            <button onclick="toggleMenu('transMenu', this)"
                    class="w-full flex items-center gap-3 px-4 py-2.5 rounded-lg hover:bg-blue-800 transition @(isTransaction ? "bg-blue-800 font-semibold" : "")">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                <span class="flex-1 text-left">Transaction Activity</span>
                <svg id="transArrow" class="w-4 h-4 transition-transform @(isTransaction ? "rotate-180" : "")" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div id="transMenu" class="mt-1 ml-8 space-y-1 @(isTransaction ? "" : "hidden")">
                <a href="@Url.Action("Index","Borrow")" class="block px-3 py-2 rounded-lg text-sm text-blue-200 hover:bg-blue-800 hover:text-white transition @(ViewContext.RouteData.Values["controller"]?.ToString() == "Borrow" ? "text-white font-medium" : "")">Book</a>
                <a href="@Url.Action("Index","Computer")" class="block px-3 py-2 rounded-lg text-sm text-blue-200 hover:bg-blue-800 hover:text-white transition @(ViewContext.RouteData.Values["controller"]?.ToString() == "Computer" ? "text-white font-medium" : "")">Computer</a>
            </div>
        </div>

        <!-- Book Management -->
        @{
            var isBook = ViewContext.RouteData.Values["controller"]?.ToString() == "Book";
        }
        <div>
            <button onclick="toggleMenu('bookMenu', this)"
                    class="w-full flex items-center gap-3 px-4 py-2.5 rounded-lg hover:bg-blue-800 transition @(isBook ? "bg-blue-800 font-semibold" : "")">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                <span class="flex-1 text-left">Book Management</span>
                <svg id="bookArrow" class="w-4 h-4 transition-transform @(isBook ? "rotate-180" : "")" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div id="bookMenu" class="mt-1 ml-8 space-y-1 @(isBook ? "" : "hidden")">
                <a href="@Url.Action("Register","Book")" class="block px-3 py-2 rounded-lg text-sm text-blue-200 hover:bg-blue-800 hover:text-white transition @(ViewContext.RouteData.Values["action"]?.ToString() == "Register" ? "text-white font-medium" : "")">Book Registration</a>
                <a href="@Url.Action("Index","Book")" class="block px-3 py-2 rounded-lg text-sm text-blue-200 hover:bg-blue-800 hover:text-white transition @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "text-white font-medium" : "")">Book Catalog</a>
                <a href="@Url.Action("Archive","Book")" class="block px-3 py-2 rounded-lg text-sm text-blue-200 hover:bg-blue-800 hover:text-white transition @(ViewContext.RouteData.Values["action"]?.ToString() == "Archive" ? "text-white font-medium" : "")">Archive Records</a>
            </div>
        </div>

        <!-- Computer Management -->
        @{
            var isComputer = ViewContext.RouteData.Values["controller"]?.ToString() == "Computer";
        }
        <div>
            <button onclick="toggleMenu('computerMenu', this)"
                    class="w-full flex items-center gap-3 px-4 py-2.5 rounded-lg hover:bg-blue-800 transition @(isComputer ? "bg-blue-800 font-semibold" : "")">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                <span class="flex-1 text-left">Computer Management</span>
                <svg id="computerArrow" class="w-4 h-4 transition-transform @(isComputer ? "rotate-180" : "")" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div id="computerMenu" class="mt-1 ml-8 space-y-1 @(isComputer ? "" : "hidden")">
                <a href="@Url.Action("Register","Computer")" class="block px-3 py-2 rounded-lg text-sm text-blue-200 hover:bg-blue-800 hover:text-white transition @(ViewContext.RouteData.Values["action"]?.ToString() == "Register" && isComputer ? "text-white font-medium" : "")">Computer Registration</a>
                <a href="@Url.Action("Index","Computer")" class="block px-3 py-2 rounded-lg text-sm text-blue-200 hover:bg-blue-800 hover:text-white transition @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" && isComputer ? "text-white font-medium" : "")">Computer List</a>
                <a href="@Url.Action("ArchiveList","Computer")" class="block px-3 py-2 rounded-lg text-sm text-blue-200 hover:bg-blue-800 hover:text-white transition @(ViewContext.RouteData.Values["action"]?.ToString() == "ArchiveList" && isComputer ? "text-white font-medium" : "")">Archive Records</a>
            </div>
        </div>

    </nav>

    <!-- Logout -->
    <div class="px-3 py-4 border-t border-blue-800">
        <form method="post" action="/Account/Logout">
            @Html.AntiForgeryToken()
            <button type="submit" class="w-full flex items-center gap-3 px-4 py-2.5 rounded-lg hover:bg-blue-800 transition text-left">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                <span>Logout</span>
            </button>
        </form>
    </div>
</aside>

<!-- Main Area -->
<div class="flex flex-col flex-1 overflow-hidden">

    <!-- Top Header -->
    <header class="bg-white border-b border-gray-200 flex items-center justify-between px-6 py-3 shadow-sm flex-shrink-0">
        <h1 class="text-lg font-semibold text-gray-700">@ViewData["Title"]</h1>
        <div class="flex items-center gap-4">
            <button class="text-gray-500 hover:text-gray-700">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
            </button>
            <button class="text-gray-500 hover:text-gray-700">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </button>
            <div class="flex items-center gap-2 text-gray-700">
                <div class="w-8 h-8 rounded-full flex items-center justify-center text-white text-sm font-bold" style="background-color:#1e3a6e;">
                    @(User.Identity?.Name?.Length > 0 ? User.Identity.Name[0].ToString().ToUpper() : "L")
                </div>
                <span class="text-sm font-medium">@User.Identity?.Name</span>
            </div>
        </div>
    </header>

    <!-- Page Content -->
    <main class="flex-1 overflow-y-auto p-6">
        @if (TempData["Success"] != null)
        {
            <div class="mb-4 px-4 py-3 bg-green-100 border border-green-300 text-green-800 rounded-lg text-sm">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="mb-4 px-4 py-3 bg-red-100 border border-red-300 text-red-800 rounded-lg text-sm">@TempData["Error"]</div>
        }
        @RenderBody()
    </main>
</div>

<script>
function toggleMenu(menuId, btn) {
    const menu = document.getElementById(menuId);
    const arrow = btn.querySelector('svg:last-child');
    menu.classList.toggle('hidden');
    if (arrow) arrow.classList.toggle('rotate-180');
}
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
