<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookHive MIS</title>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
</head>
<body class="bg-gray-100">

<div class="flex min-h-screen">

    <!-- Sidebar -->
    <aside class="w-64 text-white flex flex-col fixed top-0 left-0 h-full overflow-y-auto z-10" style="background-color:#1B2B5E;">

        <div class="h-20 flex items-center justify-center border-b border-blue-900 shrink-0">
            <div class="text-center">
                <h1 class="text-xl font-bold tracking-wide">BookHive</h1>
                <p class="text-blue-300 text-xs">MIS Facilitator Portal</p>
            </div>
        </div>

        <nav class="flex-1 p-4 space-y-1 text-sm">

            <a href="/MIS/Dashboard"
               class="flex items-center gap-3 px-4 py-2.5 rounded-xl hover:bg-blue-800 transition @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "bg-blue-900 font-semibold" : "")">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0h6"/></svg>
                Dashboard
            </a>

            <a href="/MIS/Registration"
               class="flex items-center gap-3 px-4 py-2.5 rounded-xl hover:bg-blue-800 transition @(ViewContext.RouteData.Values["action"]?.ToString() == "Registration" ? "bg-blue-900 font-semibold" : "")">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>
                Registration
            </a>

            <a href="/MIS/UserInformation"
               class="flex items-center gap-3 px-4 py-2.5 rounded-xl hover:bg-blue-800 transition @(ViewContext.RouteData.Values["action"]?.ToString() == "UserInformation" ? "bg-blue-900 font-semibold" : "")">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                User Information
            </a>

            <a href="/MIS/ArchivedUsers"
               class="flex items-center gap-3 px-4 py-2.5 rounded-xl hover:bg-blue-800 transition @(ViewContext.RouteData.Values["action"]?.ToString() == "ArchivedUsers" ? "bg-blue-900 font-semibold" : "")">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
                Archived Users
            </a>

        </nav>

        <div class="p-4 border-t border-blue-900">
            <form method="post" action="/Account/Logout">
                @Html.AntiForgeryToken()
                <button type="submit" class="flex items-center gap-2 text-sm text-blue-300 hover:text-white w-full">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                    Logout
                </button>
            </form>
        </div>

    </aside>

    <!-- Main Content -->
    <main class="flex-1 ml-64 min-h-screen">

        <!-- Header -->
        <div class="bg-white border-b border-gray-200 px-8 py-4 flex items-center justify-between">
            <div>
                <h2 class="text-xl font-bold text-gray-800">@ViewData["Title"]</h2>
                <p class="text-xs text-gray-400">MIS Facilitator Portal — STI San Jose Del Monte</p>
            </div>
            <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-full flex items-center justify-center text-white text-sm font-bold" style="background-color:#1B2B5E;">
                    MF
                </div>
            </div>
        </div>

        <div class="p-8">
            @if (TempData["Success"] != null)
            {
                <div class="mb-5 bg-green-100 border border-green-300 text-green-800 px-4 py-3 rounded-xl text-sm flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                    @TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="mb-5 bg-red-100 border border-red-300 text-red-800 px-4 py-3 rounded-xl text-sm flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    @TempData["Error"]
                </div>
            }

            @RenderBody()
        </div>

    </main>

</div>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
