@{
    ViewData["Title"] = "Microsoft 365 Login";
}

<div class="min-h-screen bg-gradient-to-r from-indigo-600 to-purple-700 flex items-center justify-center">

    <div class="bg-gray-100 w-[750px] max-w-[90vw] rounded-[70px] p-20 shadow-2xl">

        <div class="flex flex-col items-center">

            <img src="/images/bookhive_logo_v2.svg" class="w-[150px] mb-3" /> 

            <h3 class="text-xl mb-8">
                Microsoft 365 Login
            </h3>

            <form method="post"
                  class="w-full flex flex-col items-center gap-5">

                <input type="email"
                       name="email"
                       placeholder="School Email"
                       class="w-[500px] bg-gray-200 rounded-2xl px-6 py-5 text-xl outline-none" />

                <input type="password"
                       name="password"
                       placeholder="Password"
                       class="w-[500px] bg-gray-200 rounded-2xl px-6 py-5 text-xl outline-none" />

                <a href="#"
                   class="text-violet-700 hover:underline">
                    Forgot Password?
                </a>

                <button type="submit"
                        class="w-[500px] bg-violet-700 text-white text-2xl rounded-2xl py-5 hover:bg-violet-800 transition">
                    Continue
                </button>

                <div class="w-full flex justify-end mt-4">
                    <a asp-controller="Account"
                       asp-action="Login"
                       class="text-violet-700 hover:underline">
                        ← Back
                    </a>
                </div>
            </form>

        </div>

    </div>

</div>