@model BookHiveLibrary.ViewModels.VerifyPhoneOtpViewModel

@{
    ViewData["Title"] = "Verify Phone";
}

<div class="min-h-screen flex items-center justify-center bg-violet-700">

    <div class="bg-white rounded-[40px] w-[700px] p-16 flex flex-col items-center">

        <img src="/images/bookhive_logo_v2.svg" class="w-[150px] mb-3" />

        <h3 class="text-2xl font-semibold mb-2">Phone Verification</h3>

        <p class="text-gray-500 text-center mb-6">
            A 6-digit code was sent to your registered phone number.<br />
            Please enter it below to continue.
        </p>

        @if (TempData["SmsError"] != null)
        {
            <div class="w-[450px] bg-yellow-50 border border-yellow-300 text-yellow-800 text-sm px-4 py-3 rounded-xl mb-4 text-center">
                @TempData["SmsError"]
            </div>
        }

        <form method="post"
              asp-action="VerifyPhoneOtp"
              class="flex flex-col items-center w-full">

            <input asp-for="Email" type="hidden" />

            <div asp-validation-summary="All"
                 class="w-[450px] text-red-500 mb-4 text-center text-sm">
            </div>

            <input asp-for="Code"
                   placeholder="Enter 6-digit code"
                   maxlength="6"
                   autocomplete="one-time-code"
                   class="w-[450px] h-[60px] rounded-2xl bg-gray-100 px-6 text-xl mb-8 outline-none tracking-widest text-center" />

            <button type="submit"
                    class="w-[450px] h-[65px] bg-violet-700 text-white rounded-2xl text-2xl hover:bg-violet-800 transition">
                Verify
            </button>

        </form>

    </div>

</div>
