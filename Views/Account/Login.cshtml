@model BookHiveLibrary.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="min-h-screen bg-gradient-to-br from-indigo-700 to-purple-700 flex items-center justify-center relative">

    <div class="bg-white rounded-[70px] shadow-2xl w-[1150px] flex flex-col items-center pt-10 px-20 pb-10">

        <!-- Logo -->
        <img src="/images/bookhive_logo_v2.svg" class="w-[700px] mb-10" />

        @if (TempData["Error"] != null)
        {
            <div class="w-[500px] bg-red-50 border border-red-300 text-red-700 text-sm px-4 py-3 rounded-xl mb-4 text-center">
                @TempData["Error"]
            </div>
        }

        <!-- Microsoft 365 -->
        <a asp-controller="Account"
           asp-action="MicrosoftLogin"
           class="w-[500px] h-[80px] bg-white border border-gray-300 rounded-3xl shadow-md flex items-center justify-center gap-4 text-2xl hover:bg-gray-50 transition">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 21 21">
                <rect x="1" y="1" width="9" height="9" fill="#f25022"/>
                <rect x="11" y="1" width="9" height="9" fill="#00a4ef"/>
                <rect x="1" y="11" width="9" height="9" fill="#7fba00"/>
                <rect x="11" y="11" width="9" height="9" fill="#ffb900"/>
            </svg>
            Log in with Microsoft 365
        </a>

        <!-- Divider -->
        <div class="flex items-center w-[500px] my-6">
            <div class="flex-grow h-[1px] bg-gray-300"></div>
            <span class="mx-5 text-gray-400 text-base">or test login</span>
            <div class="flex-grow h-[1px] bg-gray-300"></div>
        </div>

        <!-- Test Login Form (Students & Professors) -->
        <form asp-action="StudentLogin" asp-controller="Account" method="post"
              class="flex flex-col items-center w-full">
            <div asp-validation-summary="ModelOnly" class="text-red-500 mb-3 text-center text-sm"></div>

            <input asp-for="EmailOrUsername"
                   type="text"
                   placeholder="Email or Username"
                   class="w-[500px] h-[58px] px-6 bg-gray-100 rounded-2xl text-lg outline-none shadow-sm mb-4" />

            <input asp-for="Password"
                   type="password"
                   placeholder="Password"
                   class="w-[500px] h-[58px] px-6 bg-gray-100 rounded-2xl text-lg outline-none shadow-sm mb-6" />

            <button type="submit"
                    class="w-[500px] h-[65px] rounded-3xl bg-indigo-700 text-white text-2xl font-medium shadow-lg hover:bg-indigo-800 transition">
                Sign In
            </button>
        </form>

        <!-- Divider -->
        <div class="flex items-center w-[500px] my-6">
            <div class="flex-grow h-[1px] bg-gray-300"></div>
            <span class="mx-5 text-gray-400 text-xl">or</span>
            <div class="flex-grow h-[1px] bg-gray-300"></div>
        </div>

        <!-- Admin Login -->
        <a asp-controller="Account"
           asp-action="AdminLogin"
           class="w-[500px] h-[80px] bg-violet-700 text-white rounded-3xl shadow-lg flex items-center justify-center text-2xl hover:bg-violet-800 transition">
            Admin Login
        </a>

        <!-- MIS Portal -->
        <div class="mt-6">
            <a href="/Account/MISLogin" class="text-gray-400 text-sm hover:text-gray-600 underline">
                MIS Portal
            </a>
        </div>

    </div>

</div>
