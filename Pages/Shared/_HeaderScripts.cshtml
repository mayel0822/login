<script>
    function toggleDropdown(id) {
        const targets = ['notification-dropdown', 'message-dropdown'];
        targets.forEach(t => {
            const el = document.getElementById(t);
            if (el) {
                if (t === id) {
                    el.classList.toggle('hidden');
                } else {
                    el.classList.add('hidden');
                }
            }
        });
    }

    function markAllRead() {
        document.querySelectorAll('.notification-item.unread .w-2').forEach(dot => dot.remove());
        document.querySelectorAll('.notification-item').forEach(item => item.classList.remove('unread'));
        const badge = document.getElementById('notification-badge');
        if (badge) badge.classList.add('hidden');
    }

    // Close dropdowns when clicking outside
    document.addEventListener('click', function (e) {
        if (!e.target.closest('#notification-wrapper') && !e.target.closest('#notification-dropdown')) {
            const nd = document.getElementById('notification-dropdown');
            if (nd) nd.classList.add('hidden');
        }
        if (!e.target.closest('#message-wrapper') && !e.target.closest('#message-dropdown')) {
            const md = document.getElementById('message-dropdown');
            if (md) md.classList.add('hidden');
        }
    });
</script>
