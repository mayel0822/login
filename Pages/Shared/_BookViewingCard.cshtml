@{
    var bookTitle     = ViewBag.bookTitle     ?? "Book Title";
    var author        = ViewBag.author        ?? "Author";
    var publishedYear = ViewBag.publishedYear ?? "â€”";
    var category      = ViewBag.category      ?? "â€”";
    var status        = ViewBag.status        ?? "Available";
    var qty           = ViewBag.qty           ?? "â€”";
    var location      = ViewBag.location      ?? "aisle / shelve";
    var synopsis      = ViewBag.synopsis      ?? "";

    var isAvailable  = status == "Available";
    var badgeCls     = isAvailable ? "bg-emerald-500" : "bg-red-400";
}

<div class="bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 overflow-hidden flex flex-col">

    <div class="flex gap-3 p-4">
        <!-- Book Cover -->
        <div class="w-20 h-28 flex-shrink-0 rounded-xl bg-gradient-to-br from-[#c5cfe0] to-[#a8b8cc] shadow-inner"></div>

        <!-- Details -->
        <div class="flex-1 min-w-0">
            <!-- Three-dot -->
            <div class="flex justify-end mb-1">
                <button class="text-gray-300 hover:text-gray-500 transition" aria-label="Options">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M6 10a2 2 0 11-4 0 2 2 0 014 0zm6 0a2 2 0 11-4 0 2 2 0 014 0zm6 0a2 2 0 11-4 0 2 2 0 014 0z"/>
                    </svg>
                </button>
            </div>

            <dl class="space-y-0.5 text-[11px] text-[#2c3e6b]">
                <div><span class="font-semibold">Book Title:</span> @bookTitle</div>
                <div><span class="font-semibold">Author:</span> @author</div>
                <div><span class="font-semibold">Published Year:</span> @publishedYear</div>
                <div><span class="font-semibold">Category:</span> @category</div>
                <div class="flex items-center gap-1">
                    <span class="font-semibold">Status:</span>
                    <span class="inline-block @badgeCls text-white text-[10px] font-semibold px-2 py-0.5 rounded-full">@status</span>
                </div>
                <div><span class="font-semibold">Qty:</span> @qty</div>
                <div><span class="font-semibold">Loc:</span> @location</div>
            </dl>
        </div>
    </div>

    <!-- Divider -->
    <div class="mx-4 border-t border-gray-100"></div>

    <!-- Synopsis + Reserve -->
    <div class="px-4 py-3 flex-1 flex flex-col">
        <p class="text-[11px] font-semibold text-[#2c3e6b] mb-1">Book Synopsis:</p>
        <p class="text-[11px] text-gray-400 flex-1 mb-4 leading-relaxed min-h-[2rem]">@(string.IsNullOrEmpty(synopsis) ? "No synopsis available." : synopsis)</p>

        <div class="flex justify-end">
            <button class="bg-[#1e3a5f] hover:bg-[#16304f] active:bg-[#0f2540] text-white text-xs font-semibold px-6 py-1.5 rounded-full transition-all duration-150 shadow-sm hover:shadow">
                Reserve
            </button>
        </div>
    </div>

</div>
