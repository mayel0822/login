<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookHiveLibrary</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#1e3a5f',
                        secondary: '#4a7ba7',
                        dark: '#1a1a1a',
                        darkCard: '#2a2a2a'
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-gray-900 text-white">
    @RenderBody()
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
