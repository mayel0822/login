@{
    var bookTitle = ViewBag.bookTitle ?? "Book Title";
    var author = ViewBag.author ?? "Author";
    var dueDate = ViewBag.dueDate ?? "00/00/00";
}

<div class="flex justify-between items-start pb-4 border-b border-gray-100 last:border-b-0">
    <div>
        <p class="text-[#1e3a5f] font-semibold">@bookTitle</p>
        <p class="text-sm text-gray-500">@author</p>
        <p class="text-xs text-gray-400 mt-1">Due Date: @dueDate</p>
    </div>
    <span class="bg-red-500 text-white text-xs px-3 py-1 rounded-full whitespace-nowrap">Overdue</span>
</div>
