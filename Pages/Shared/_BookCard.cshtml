@{
    var bookTitle = ViewBag.bookTitle ?? "Book Title";
    var author = ViewBag.author ?? "Author";
    var status = ViewBag.status ?? "Available";
}

<div class="bg-[#b0c4d8] rounded-2xl overflow-hidden hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200">
    <div class="w-full h-36 bg-[#1e3a5f]/10 flex items-center justify-center">
        <svg class="w-10 h-10 text-[#1e3a5f]/30" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/>
        </svg>
    </div>

    <div class="p-4">
        <h3 class="font-semibold text-[#1e3a5f] mb-1 truncate">@bookTitle</h3>
        <p class="text-sm text-[#1e3a5f]/60 mb-3 truncate">@author</p>

        <div class="flex gap-2 mb-3">
            <span class="inline-block bg-emerald-500 text-white text-xs px-3 py-1 rounded-full">@status</span>
        </div>

        <button class="w-full bg-[#1e3a5f] hover:bg-[#16305a] text-white py-2 rounded-xl transition font-medium text-sm">
            Reserve
        </button>
    </div>
</div>
