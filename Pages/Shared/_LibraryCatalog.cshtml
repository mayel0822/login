<div class="bg-white rounded-2xl p-6 shadow-sm">
    <!-- Header -->
    <div class="flex items-center gap-4 mb-6 flex-wrap">
        <h2 class="text-lg font-bold text-[#1e3a5f] flex-1">Library Book Catalog</h2>

        <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/>
            </svg>
            <input type="text" placeholder="Search"
                   class="pl-9 pr-4 py-2 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#1e3a5f]/30 bg-gray-50 w-36 sm:w-52 transition"/>
        </div>

        <select class="text-sm border border-gray-200 rounded-xl px-3 py-2 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-[#1e3a5f]/30 text-gray-600 transition">
            <option>Category</option>
            <option>Fiction</option>
            <option>Non-Fiction</option>
            <option>Science</option>
            <option>History</option>
        </select>
    </div>

    <!-- Books Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 mb-4">
        @for (int i = 0; i < 3; i++)
        {
            @await Html.PartialAsync("_BookCard", new { bookTitle = "Book Title", author = "Author", status = "Available" })
        }
    </div>

    <!-- Load More -->
    <div class="flex justify-center">
        <button class="text-[#1e3a5f]/50 hover:text-[#1e3a5f] transition p-2">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
            </svg>
        </button>
    </div>
</div>
