<div id="notification-dropdown"
     class="hidden absolute right-0 top-full mt-2 w-80 bg-white rounded-2xl shadow-xl border border-gray-100 z-50 overflow-hidden">

    <!-- Header -->
    <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
        <h3 class="text-sm font-bold text-[#1e3a5f]">Notifications</h3>
        <button onclick="markAllRead()" class="text-xs text-[#1e3a5f]/60 hover:text-[#1e3a5f] transition font-medium">
            Mark all as read
        </button>
    </div>

    <!-- Notification Items -->
    <ul class="divide-y divide-gray-50 max-h-72 overflow-y-auto">
        <li class="flex gap-3 px-4 py-3 hover:bg-gray-50 transition cursor-pointer notification-item unread">
            <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-[#1e3a5f]" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/>
                </svg>
            </div>
            <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-[#1e3a5f]">Book reservation approved</p>
                <p class="text-xs text-gray-500 truncate">Your reservation for "The Great Gatsby" has been approved.</p>
                <p class="text-xs text-gray-400 mt-1">2 minutes ago</p>
            </div>
            <span class="w-2 h-2 rounded-full bg-blue-500 flex-shrink-0 mt-2"></span>
        </li>

        <li class="flex gap-3 px-4 py-3 hover:bg-gray-50 transition cursor-pointer notification-item unread">
            <div class="w-8 h-8 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-red-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
                </svg>
            </div>
            <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-[#1e3a5f]">Return reminder</p>
                <p class="text-xs text-gray-500 truncate">"Sapiens" is due in 12 hours. Please return it on time.</p>
                <p class="text-xs text-gray-400 mt-1">1 hour ago</p>
            </div>
            <span class="w-2 h-2 rounded-full bg-blue-500 flex-shrink-0 mt-2"></span>
        </li>

        <li class="flex gap-3 px-4 py-3 hover:bg-gray-50 transition cursor-pointer notification-item">
            <div class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-emerald-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M3 5a2 2 0 012-2h10a2 2 0 012 2v8a2 2 0 01-2 2h-2.22l.123.489.804.804A1 1 0 0113 18H7a1 1 0 01-.707-1.707l.804-.804L7.22 15H5a2 2 0 01-2-2V5zm5.771 7H5V5h10v7H8.771z" clip-rule="evenodd"/>
                </svg>
            </div>
            <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-[#1e3a5f]">Computer slot available</p>
                <p class="text-xs text-gray-500 truncate">PC-003 is now available for use.</p>
                <p class="text-xs text-gray-400 mt-1">Yesterday</p>
            </div>
        </li>

        <li class="flex gap-3 px-4 py-3 hover:bg-gray-50 transition cursor-pointer notification-item">
            <div class="w-8 h-8 rounded-full bg-yellow-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                </svg>
            </div>
            <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-[#1e3a5f]">Overdue notice</p>
                <p class="text-xs text-gray-500 truncate">"Clean Code" was due yesterday. Please return immediately.</p>
                <p class="text-xs text-gray-400 mt-1">2 days ago</p>
            </div>
        </li>
    </ul>

    <!-- Footer -->
    <div class="px-4 py-2 border-t border-gray-100 text-center">
        <a href="#" class="text-xs font-medium text-[#1e3a5f]/60 hover:text-[#1e3a5f] transition">View all notifications</a>
    </div>
</div>
