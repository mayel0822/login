<div class="bg-white rounded-2xl p-6 shadow-sm">
    <div class="flex justify-between items-center mb-4">
        <h2 class="text-lg font-bold text-[#1e3a5f]">Books To Return</h2>
        <button class="text-gray-400 hover:text-[#1e3a5f] transition text-xl" aria-label="More options">⋮</button>
    </div>

    <div class="space-y-4">
        @for (int i = 0; i < 2; i++)
        {
            @await Html.PartialAsync("_ReturnItem", new { bookTitle = "BookTitle", author = "Author", dueDate = i == 0 ? "06/15/26" : "06/18/26" })
        }
    </div>
</div>
