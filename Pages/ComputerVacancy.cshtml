@page
@model BookHiveDashBoard.Pages.ComputerVacancyModel
@{
    ViewData["Title"] = "Computer Vacancy";

    var computers = new[]
    {
        new { Id = "PC-001", Available = true },
        new { Id = "PC-002", Available = true },
        new { Id = "PC-003", Available = false },
        new { Id = "PC-004", Available = false },
        new { Id = "PC-005", Available = true },
        new { Id = "PC-006", Available = true },
    };

    int availableCount = computers.Count(c => c.Available);
    int occupiedCount  = computers.Count(c => !c.Available);
}

<style>
    @@keyframes pulse-dot {
        0%, 100% { opacity: 1; transform: scale(1); }
        50%       { opacity: .6; transform: scale(1.3); }
    }
    .pulse { animation: pulse-dot 1.8s ease-in-out infinite; }
</style>

<!-- Mobile sidebar backdrop -->
<div id="sidebar-backdrop" class="fixed inset-0 bg-black/40 z-40 hidden" onclick="toggleSidebar()"></div>

<div class="flex h-screen bg-[#dce6f5]">

    <!-- Sidebar -->
    <aside id="sidebar" class="fixed inset-y-0 left-0 z-50 w-56 bg-[#1e3a5f] text-white flex flex-col py-8 px-5 flex-shrink-0 shadow-xl -translate-x-full lg:translate-x-0 lg:relative transition-transform duration-300">
        <div class="mb-10 flex items-center justify-between">
            <a href="/Dashboard" class="flex items-center gap-1">
                <span class="text-3xl font-black italic text-white leading-none font-serif">B</span>
                <span class="text-xl font-bold text-white tracking-tight">ookHive</span>
            </a>
            <button onclick="toggleSidebar()" class="lg:hidden text-white/60 hover:text-white transition">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <nav class="space-y-1 flex-1">
            <a href="/Dashboard"
               class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-blue-200 hover:bg-white/10 hover:text-white transition-all duration-200">
                <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
                </svg>
                Home
            </a>

            <a href="/BookViewing"
               class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-blue-200 hover:bg-white/10 hover:text-white transition-all duration-200">
                <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/>
                </svg>
                Book Viewing
            </a>

            <a href="/ComputerVacancy"
               class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-semibold bg-white/20 text-white ring-1 ring-white/10">
                <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M3 5a2 2 0 012-2h10a2 2 0 012 2v8a2 2 0 01-2 2h-2.22l.123.489.804.804A1 1 0 0113 18H7a1 1 0 01-.707-1.707l.804-.804L7.22 15H5a2 2 0 01-2-2V5zm5.771 7H5V5h10v7H8.771z" clip-rule="evenodd"/>
                </svg>
                Computer Vacancy
            </a>
        </nav>
    </aside>

    <!-- Main -->
    <main class="flex-1 flex flex-col overflow-hidden">

        <!-- Header -->
        <header class="bg-[#dce6f5] px-4 sm:px-8 py-5 flex items-center justify-between flex-shrink-0">
            <div class="flex items-center gap-3">
                <button onclick="toggleSidebar()" class="lg:hidden text-[#1e3a5f] hover:opacity-60 transition" aria-label="Open menu">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
                    </svg>
                </button>
                <h1 class="text-xl sm:text-2xl font-bold text-[#1e3a5f]">Computer Vacancy</h1>
            </div>
            <div class="flex items-center gap-3 sm:gap-5 text-[#1e3a5f]">

                <!-- Notification Bell -->
                <div id="notification-wrapper" class="relative">
                    <button onclick="toggleDropdown('notification-dropdown')" aria-label="Notifications"
                            class="relative hover:opacity-60 transition">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6 6 0 10-12 0v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
                        </svg>
                        <span id="notification-badge"
                              class="absolute -top-1 -right-1 w-4 h-4 bg-red-500 text-white text-[9px] font-bold rounded-full flex items-center justify-center">
                            2
                        </span>
                    </button>
                    @await Html.PartialAsync("_NotificationDropdown")
                </div>

                <!-- Messages -->
                <div id="message-wrapper" class="relative">
                    <button onclick="toggleDropdown('message-dropdown')" aria-label="Messages"
                            class="relative hover:opacity-60 transition">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                        </svg>
                        <span class="absolute -top-1 -right-1 w-4 h-4 bg-red-500 text-white text-[9px] font-bold rounded-full flex items-center justify-center">
                            2
                        </span>
                    </button>
                    @await Html.PartialAsync("_MessageDropdown")
                </div>

                <div class="flex items-center gap-2 pl-3 sm:pl-4 border-l border-[#1e3a5f]/20">
                    <span class="hidden sm:inline text-sm font-medium">SampleNameHere</span>
                    <div class="w-8 h-8 rounded-full bg-[#1e3a5f] flex items-center justify-center text-white flex-shrink-0">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                        </svg>
                    </div>
                </div>
            </div>
        </header>
        @await Html.PartialAsync("_HeaderScripts")

        <!-- Content -->
        <div class="flex-1 overflow-y-auto px-4 sm:px-8 pb-8">
            <div class="bg-white rounded-2xl p-4 sm:p-6 shadow-sm">

                <!-- Summary bar -->
                <div class="flex items-center justify-between mb-6 flex-wrap gap-2">
                    <h2 class="text-lg font-bold text-[#1e3a5f]">Lab Overview</h2>
                    <div class="flex items-center gap-4 text-sm">
                        <span class="flex items-center gap-1.5 text-emerald-600 font-semibold">
                            <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 inline-block"></span>
                            @availableCount Available
                        </span>
                        <span class="flex items-center gap-1.5 text-red-500 font-semibold">
                            <span class="w-2.5 h-2.5 rounded-full bg-red-400 inline-block"></span>
                            @occupiedCount Occupied
                        </span>
                    </div>
                </div>

                <!-- PC Grid — 1 col mobile, 2 col sm+ -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    @foreach (var pc in computers)
                    {
                        var cardBg    = pc.Available ? "bg-[#b0c4d8]" : "bg-[#b0bec5]";
                        var dotColor  = pc.Available ? "bg-emerald-400" : "bg-red-400";
                        var dotPulse  = pc.Available ? "pulse" : "";
                        var badgeCls  = pc.Available ? "bg-emerald-500 text-white" : "bg-red-400 text-white";
                        var badgeText = pc.Available ? "Available" : "Not Available";

                        <div class="@cardBg rounded-2xl p-5 relative hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 cursor-default">
                            <span class="absolute top-4 right-4 w-3 h-3 rounded-full @dotColor @dotPulse block"></span>

                            <div class="mb-3 text-[#1e3a5f]/40">
                                <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M21 2H3a2 2 0 00-2 2v12a2 2 0 002 2h7l-2 3v1h8v-1l-2-3h7a2 2 0 002-2V4a2 2 0 00-2-2zm0 14H3V4h18v12z"/>
                                </svg>
                            </div>

                            <p class="text-2xl font-extrabold text-[#1e3a5f] mb-3 tracking-tight">@pc.Id</p>
                            <span class="inline-block @badgeCls text-xs font-semibold px-3 py-1 rounded-full">@badgeText</span>
                        </div>
                    }
                </div>

            </div>
        </div>

    </main>
</div>

<script>
    function toggleSidebar() {
        const sidebar = document.getElementById('sidebar');
        const backdrop = document.getElementById('sidebar-backdrop');
        const isOpen = !sidebar.classList.contains('-translate-x-full');
        if (isOpen) {
            sidebar.classList.add('-translate-x-full');
            backdrop.classList.add('hidden');
        } else {
            sidebar.classList.remove('-translate-x-full');
            backdrop.classList.remove('hidden');
        }
    }
</script>
